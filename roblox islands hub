		Name = name,
		Size = UDim2.new(1, 0, 0, height),
		BorderSizePixel = 0,
		Parent = parent,
	})
	card:SetAttribute("Searchable", true)
	card:SetAttribute("SearchText", name)
	self:_bindTheme(card, "BackgroundColor3", "Surface")
	corner(card, 9)
	local stroke = create("UIStroke", { Thickness = 1, Transparency = 0.65, Parent = card })
	self:_bindTheme(stroke, "Color", "Border")
	return card
end

