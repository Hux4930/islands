local Workspace = game:GetService("Workspace")

local BLOCK_SIZE = 3
local HITBOX_MERGE_OVERLAP = 0.5
local PREVIEW_MODEL_NAME = "IslandsSchematicOnlyPreview"
local HIGHLIGHT_NAME = "StackCountHighlight"
local REFRESH_SECONDS = 1

local STACK_COLORS = {
	[2] = Color3.fromRGB(255, 210, 40),
	[3] = Color3.fromRGB(190, 70, 255)
}

local environment = getgenv and getgenv() or _G
if environment.IslandsStackHighlighterStop then
	environment.IslandsStackHighlighterStop()
end

local running = true

local function getPreviewBlocks()
	local preview = Workspace:FindFirstChild(PREVIEW_MODEL_NAME)
	if not preview then return {} end

	local blocks = {}
	for _, child in ipairs(preview:GetChildren()) do
		if child:IsA("BasePart") and child.Name ~= "PrimaryPart" then
			table.insert(blocks, child)
		end
	end
	return blocks
end

local function getPartAabb(part)
	local half = part.Size / 2
	local minX, minY, minZ = math.huge, math.huge, math.huge
	local maxX, maxY, maxZ = -math.huge, -math.huge, -math.huge

	for x = -1, 1, 2 do
		for y = -1, 1, 2 do
			for z = -1, 1, 2 do
				local point = part.CFrame:PointToWorldSpace(Vector3.new(
					half.X * x,
					half.Y * y,
					half.Z * z
				))
				minX = math.min(minX, point.X)
				minY = math.min(minY, point.Y)
				minZ = math.min(minZ, point.Z)
				maxX = math.max(maxX, point.X)
				maxY = math.max(maxY, point.Y)
				maxZ = math.max(maxZ, point.Z)
			end
		end
	end

	return Vector3.new(minX, minY, minZ), Vector3.new(maxX, maxY, maxZ)
end

local function getBlockHitboxes(block)
	local hitboxes = {}
	for _, child in ipairs(block:GetChildren()) do
		if child:IsA("BasePart") and child:GetAttribute("IsPreviewHitbox") == true then
			local minPos, maxPos = getPartAabb(child)
			table.insert(hitboxes, { min = minPos, max = maxPos })
		end
	end

	if #hitboxes == 0 then
		local minPos, maxPos = getPartAabb(block)
		table.insert(hitboxes, { min = minPos, max = maxPos })
	end
	return hitboxes
end

local function hitboxesOverlap(first, second)
	local overlapX = math.min(first.max.X, second.max.X) - math.max(first.min.X, second.min.X)
	local overlapY = math.min(first.max.Y, second.max.Y) - math.max(first.min.Y, second.min.Y)
	local overlapZ = math.min(first.max.Z, second.max.Z) - math.max(first.min.Z, second.min.Z)
	return overlapX > HITBOX_MERGE_OVERLAP
		and overlapY > HITBOX_MERGE_OVERLAP
		and overlapZ > HITBOX_MERGE_OVERLAP
end

local function blocksOverlap(first, second)
	for _, firstHitbox in ipairs(first.hitboxes) do
		for _, secondHitbox in ipairs(second.hitboxes) do
			if hitboxesOverlap(firstHitbox, secondHitbox) then
				return true
			end
		end
	end
	return false
end

local function getCandidateCells(hitboxes)
	local cells = {}
	for _, hitbox in ipairs(hitboxes) do
		local minX = math.floor(hitbox.min.X / BLOCK_SIZE)
		local minY = math.floor(hitbox.min.Y / BLOCK_SIZE)
		local minZ = math.floor(hitbox.min.Z / BLOCK_SIZE)
		local maxX = math.floor(hitbox.max.X / BLOCK_SIZE)
		local maxY = math.floor(hitbox.max.Y / BLOCK_SIZE)
		local maxZ = math.floor(hitbox.max.Z / BLOCK_SIZE)

		for x = minX, maxX do
			for y = minY, maxY do
				for z = minZ, maxZ do
					cells[string.format("%d:%d:%d", x, y, z)] = true
				end
			end
		end
	end
	return cells
end

