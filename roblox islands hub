function Framework:AddTab(tabOptions)
	local options = if type(tabOptions) == "string" then { Name = tabOptions } else tabOptions
	assert(type(options) == "table", "AddTab expects a name or options table")
	local name = options.Name
	assert(type(name) == "string" and name ~= "", "Tab name is required")
	if self.Tabs[name] then
		return self.Tabs[name]
	end
	local button = create("TextButton", {
		Name = name,
		Size = UDim2.new(1, 0, 0, 38),
		BackgroundTransparency = 1,
		AutoButtonColor = false,
		Font = Enum.Font.GothamSemibold,
		Text = name,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = self.Sidebar,
	})
	padding(button, 12, 0)
	corner(button, 8)
	self:_bindTheme(button, "TextColor3", "MutedText")
	local page = create("ScrollingFrame", {
		Name = name,
		Size = UDim2.fromScale(1, 1),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Visible = false,
		CanvasSize = UDim2.new(),
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		ScrollBarThickness = 3,
		Parent = self.Pages,
	})
	padding(page, 16, 16)
	create("UIListLayout", {
		Padding = UDim.new(0, 10),
		SortOrder = Enum.SortOrder.LayoutOrder,
		Parent = page,
	})
	local tab = {
		Name = name,
		Button = button,
		Page = page,
		Loader = options.Loader,
		Loaded = options.Loader == nil,
		Loading = false,
	}
	self.Tabs[name] = tab
	self:_track(button.Activated:Connect(function()
		self:SelectTab(name)
	end))
	if not self.ActiveTab then
		self:SelectTab(name)
	end
	return tab
end

function Framework:_loadTab(tab)
	if tab.Loaded or tab.Loading or type(tab.Loader) ~= "function" then
		return
	end
	tab.Loading = true
	local status = self:_makeLabel(tab.Page, "Loading...", UDim2.new(1, 0, 0, 44))
	status.Name = "LoadingStatus"
	status.TextXAlignment = Enum.TextXAlignment.Center
	self:_bindTheme(status, "TextColor3", "MutedText")

	task.spawn(function()
		local success, message = xpcall(function()
			tab.Loader(tab)
		end, debug.traceback)
		tab.Loading = false
		if status.Parent then
			status:Destroy()
		end
		if success then
			tab.Loaded = true
		else
			tab.Loaded = false
			local errorCard = self:_makeCard(tab.Page, "Load Error", 76)
			local errorLabel = self:_makeLabel(errorCard, "Could not load this tab:\n" .. tostring(message))
			errorLabel.TextWrapped = true
			errorLabel.TextSize = 11
			self:_bindTheme(errorLabel, "TextColor3", "Error")
			warn(("[GUIFramework] Tab %q failed to load:\n%s"):format(tab.Name, tostring(message)))
		end
	end)
end

function Framework:SelectTab(name)
	local target = self.Tabs[name]
	if not target then
		return false
	end
	for _, tab in self.Tabs do
		local selected = tab == target
		tab.Page.Visible = selected
		tab.Button.BackgroundTransparency = if selected then 0 else 1
		self:_bindTheme(tab.Button, "BackgroundColor3", "SurfaceAlt")
		self:_bindTheme(tab.Button, "TextColor3", if selected then "Text" else "MutedText")
	end
	self.ActiveTab = target
	self:_loadTab(target)
	self:_applySearch(self.SearchBox.Text)
	return true
end

function Framework:_applySearch(query)
	if not self.ActiveTab then
		return
	end
	query = string.lower(query)
	for _, child in self.ActiveTab.Page:GetChildren() do
		if child:IsA("GuiObject") and child:GetAttribute("Searchable") then
			local text = string.lower(child:GetAttribute("SearchText") or child.Name)
			child.Visible = query == "" or string.find(text, query, 1, true) ~= nil
		end
	end
end

