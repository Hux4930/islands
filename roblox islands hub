function getCollisionBoxParts(blockFolder)
	local collisionFolder = blockFolder and blockFolder:FindFirstChild("CollisionBoxes")
	if not collisionFolder then return {} end

	local parts = {}
	for _, child in ipairs(collisionFolder:GetDescendants()) do
		if child:IsA("BasePart") then
			table.insert(parts, child)
		end
	end
	return parts
end

function syncPreviewBlockCollision(previewBlock)
	if not previewBlock or not previewBlock:IsA("BasePart") then return end
	local hasHitboxes = previewBlock:GetAttribute("HasPreviewHitboxes") == true
	previewBlock.CanCollide = buildCollision and not hasHitboxes

	for _, child in ipairs(previewBlock:GetChildren()) do
		if child:IsA("BasePart") and child:GetAttribute("IsPreviewHitbox") == true then
			child.CanCollide = buildCollision
			setPartQueryFlags(child, true, buildCollision)
		end
	end
end

function attachPreviewCollisionBoxes(previewBlock, blockFolder, root, worldCFrame)
	local collisionParts = getCollisionBoxParts(blockFolder)
	if #collisionParts == 0 then return false end

	for _, sourceBox in ipairs(collisionParts) do
		local relative = root.CFrame:ToObjectSpace(sourceBox.CFrame)
		local hitbox = sourceBox:Clone()
		for _, descendant in ipairs(hitbox:GetDescendants()) do
			if descendant:IsA("WeldConstraint") or descendant:IsA("JointInstance") then
				descendant:Destroy()
			end
		end
		hitbox.Name = "Hitbox_" .. tostring(sourceBox.Name)
		hitbox.Anchored = false
		hitbox.Massless = true
		hitbox.Locked = false
		hitbox.CastShadow = false
		hitbox.Material = Enum.Material.ForceField
		hitbox.Color = Color3.fromRGB(255, 215, 90)
		hitbox.Transparency = math.max(0.35, math.min(0.85, hitbox.Transparency))
		hitbox.CFrame = worldCFrame:ToWorldSpace(relative)
		hitbox.Parent = previewBlock
		hitbox:SetAttribute("IsPreviewHitbox", true)
		setPartQueryFlags(hitbox, true, buildCollision)

		local weld = Instance.new("WeldConstraint")
		weld.Part0 = previewBlock
		weld.Part1 = hitbox
		weld.Parent = hitbox
	end

	previewBlock:SetAttribute("HasPreviewHitboxes", true)
	return true
end

getPositionOnlyKey = function(position)
