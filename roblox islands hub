                return island
            end

            local portal = island:FindFirstChild("portalToSpawn", true)
            local position = portal and getInstancePosition(portal)
                or getInstancePosition(island)

            if position then
                local distance = (position - rootPart.Position).Magnitude
                if distance < nearestDistance then
                    nearestDistance = distance
                    nearestIsland = island
                end
            end
        end
    end

    local children = islands:GetChildren()
    if nearestIsland then
        print("[Miner] Auto-detected nearest player island:", nearestIsland.Name)
        return nearestIsland
    elseif #children == 1 then
