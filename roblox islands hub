local function saveDepositSettings()
	writefile(DEPOSIT_SETTINGS_FILE, HttpService:JSONEncode(depositSettings))
end

local function getDepositQuantity(tool)
	if not tool then return 0 end
	for _, name in ipairs({
		"amount", "Amount", "quantity", "Quantity", "stackSize", "StackSize"
	}) do
		local value = tool:GetAttribute(name)
		if typeof(value) == "number" then return math.max(0, math.floor(value)) end
	end
	for _, name in ipairs({
		"amount", "Amount", "quantity", "Quantity", "stackSize", "StackSize"
	}) do
		local object = tool:FindFirstChild(name)
		if object and (object:IsA("IntValue") or object:IsA("NumberValue")) then
			return math.max(0, math.floor(object.Value))
		end
	end
	return 1
end

local function getDepositPosition(instance)
	if instance:IsA("BasePart") then return instance.Position end
	if instance:IsA("Model") then return instance:GetPivot().Position end
	local part = instance:FindFirstChildWhichIsA("BasePart", true)
	return part and part.Position or nil
end

local function findNearestDepositChest()
	local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	local islands = Workspace:FindFirstChild("Islands")
	if not root or not islands then return nil end
	local nearest, nearestDistance = nil, math.huge
	for _, instance in ipairs(islands:GetDescendants()) do
		if instance.Name == "diamondChestT2" then
			local position = getDepositPosition(instance)
			if position then
				local distance = (root.Position - position).Magnitude
				if distance < nearestDistance then
					nearest, nearestDistance = instance, distance
				end
			end
		end
	end
	return nearest, nearestDistance
end

local function refreshDepositChest()
	local chest, distance = findNearestDepositChest()
	DepositChestStatus:SetDesc(chest
		and string.format("%s | %.1f studs away", chest.Name, distance)
		or "no diamondChestT2 found")
	return chest
end

local function getDepositItemNames()
	local backpack = LocalPlayer:FindFirstChild("Backpack")
	local names, seen = {}, {}
	if backpack then
		for _, child in ipairs(backpack:GetChildren()) do
			if child:IsA("Tool") and not seen[child.Name] then
				seen[child.Name] = true
				table.insert(names, child.Name)
			end
		end
	end
	if selectedDepositItem ~= "" and not seen[selectedDepositItem] then
		table.insert(names, selectedDepositItem)
	end
	table.sort(names, function(left, right) return left:lower() < right:lower() end)
	return names
end

local function findDepositTool()
	local backpack = LocalPlayer:FindFirstChild("Backpack")
	if not backpack or selectedDepositItem == "" then return nil end
	local tool = backpack:FindFirstChild(selectedDepositItem)
	return tool and tool:IsA("Tool") and tool or nil
end

local function refreshDepositItems()
	if not DepositItemDropdown then return end
	DepositItemDropdown:SetValues(getDepositItemNames())
	if selectedDepositItem ~= "" then
		pcall(function() DepositItemDropdown:SetValue(selectedDepositItem) end)
