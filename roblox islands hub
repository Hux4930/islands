local function spawnPreviewBlock(blockName, worldCFrame)
	local previewName = normalizePreviewBlockName(blockName)
	local blockFolder = blocksFolder:FindFirstChild(previewName)
	if not blockFolder then warn("Preview block folder missing:", previewName); return nil end
	local root = blockFolder:FindFirstChild("Root")
	if not root then warn("Preview root missing:", previewName); return nil end

	local previewBlock             = root:Clone()
	previewBlock.Name              = previewName
	previewBlock.Anchored          = true
	previewBlock.CanCollide        = buildCollision
	previewBlock.Transparency      = 0.5
	previewBlock.Locked            = false
	previewBlock.Parent            = cloneFolder
	previewBlock.CFrame            = worldCFrame
	previewBlock:SetAttribute("StackPositionKey", getPositionOnlyKey(worldCFrame.Position))
	attachPreviewCollisionBoxes(previewBlock, blockFolder, root, worldCFrame)
	syncPreviewBlockCollision(previewBlock)
	return previewBlock
end

local function loadDecodedSchematic(decoded)
	if not decoded then return false, "No decoded schematic data." end
	clearPreview()
	cloneFolder.Parent = nil
	local placed = 0
	local processed = 0

	local function markPreviewLoaded()
		processed = processed + 1
		if processed % previewLoadYieldEvery == 0 then
			PreviewStatus:SetDesc(string.format("loading preview... %d block(s)", placed))
			task.wait()
		end
	end

	local decodedBlocks = decoded.Blocks or decoded.blocks
	if decodedBlocks then
		local origin = decoded.Origin or decoded.origin or { 0, 0, 0 }
		local originCFrame = CFrame.new(
			tonumber(origin[1]) or 0,
			tonumber(origin[2]) or 0,
			tonumber(origin[3]) or 0
		)
		for blockName, blockList in pairs(decodedBlocks) do
			for _, block in ipairs(blockList) do
				if block.C then
					local relative = CFrame.new(table.unpack(block.C))
					local world    = originCFrame:ToWorldSpace(relative)
					if spawnPreviewBlock(blockName, world) then placed = placed + 1 end
					markPreviewLoaded()
				end
			end
		end
	else
		for blockName, blockList in pairs(decoded) do
			for _, block in ipairs(blockList) do
				local x = tonumber(block[1]) or 0
				local y = tonumber(block[2]) or 0
				local z = tonumber(block[3]) or 0
				if spawnPreviewBlock(blockName, CFrame.new(x, y, z)) then placed = placed + 1 end
				markPreviewLoaded()
			end
		end
	end

	cloneFolder.Parent = Workspace
	updatePreviewStatus()
	updateBlocksStatus()
	if placed == 0 then return false, "No preview blocks could be loaded." end
	return true, placed
end

local function loadSchematicText(text)
	local decoded, cleanedOrError = decodeSchematicText(text)
	if not decoded then return false, cleanedOrError end
	lastSavedJson = cleanedOrError
	return loadDecodedSchematic(decoded)
end

