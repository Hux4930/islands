StorageSection:AddButton({
	Title = "Save Selection To File", Description = "",
	Callback = function()
		local blocks, err = getSelectionBlocks()
		if not blocks then notify("Save", tostring(err), 4); return end
		local data    = buildSchematicData(blocks)

		-- Embed only totems inside the selected region.
		local totems, totemErr = scanTotems(true)
		if totems and #totems > 0 then
			local totemData = {}
			for _, t in ipairs(totems) do
				table.insert(totemData, { name = t.name, upgrades = t.upgrades })
			end
			data.TotemData = totemData
			notify("Save", string.format("Embedded %d selected totem(s) into save.", #totems), 3)
		elseif totemErr then
			notify("Save", "Note: no selected totem data embedded - " .. tostring(totemErr), 4)
		end

		local encoded = HttpService:JSONEncode(data)
		local path    = getSchematicPath(currentFileName)
		writefile(path, encoded)
		lastSavedJson = encoded
		currentFileName = ensureJsonExtension(currentFileName)
		FileDropdown:SetValues(getSchematicFileNames())
		notify("Save", "Selection saved to " .. extractFileName(path), 4)
	end
})

