		for _, handle in pairs(previewDragHandles) do
			if Mouse.Target == handle.knob or Mouse.Target == handle.line then
				clickedHandle = handle
				break
			end
		end
	end

	if clickedHandle then
		local blocks = getPreviewBlocks()
		if #blocks == 0 then return end
		previewDragActive = true
