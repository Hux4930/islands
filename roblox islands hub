-- Modules registered before Start are included alongside discovered modules.
local registeredModules = {}

local function create(className, properties, children)
	local object = Instance.new(className)
	if properties then
		for property, value in properties do
			if property ~= "Parent" then
				object[property] = value
			end
		end
	end
	if children then
		for _, child in children do
			child.Parent = object
		end
	end
	if properties and properties.Parent then
		object.Parent = properties.Parent
	end
	return object
end

local function corner(parent, radius)
	return create("UICorner", {
		CornerRadius = UDim.new(0, radius or 8),
		Parent = parent,
	})
end

local function padding(parent, horizontal, vertical)
	local y = vertical or horizontal
	return create("UIPadding", {
		PaddingLeft = UDim.new(0, horizontal),
		PaddingRight = UDim.new(0, horizontal),
		PaddingTop = UDim.new(0, y),
		PaddingBottom = UDim.new(0, y),
		Parent = parent,
	})
end

local function tween(object, duration, properties)
	local animation = TweenService:Create(
		object,
		TweenInfo.new(duration, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
		properties
	)
	animation:Play()
	return animation
end

local function safeCall(label, callback, ...)
	if type(callback) ~= "function" then
		return true
	end
	local arguments = table.pack(...)
	local success, message = xpcall(function()
		callback(table.unpack(arguments, 1, arguments.n))
	end, debug.traceback)
	if not success then
		warn(("[GUIFramework] %s failed:\n%s"):format(label, tostring(message)))
	end
	return success
end

local function clampNumber(value, minimum, maximum, step)
	local result = math.clamp(tonumber(value) or minimum, minimum, maximum)
	if step and step > 0 then
		result = minimum + math.round((result - minimum) / step) * step
	end
	return math.clamp(result, minimum, maximum)
end

local function colorToHex(color)
	return string.format(
		"#%02X%02X%02X",
		math.round(color.R * 255),
		math.round(color.G * 255),
		math.round(color.B * 255)
	)
end

local function parseColor(value, fallback)
	if typeof(value) == "Color3" then
		return value
	end
	if type(value) == "string" then
		local hex = value:gsub("#", ""):gsub("%s", "")
		if #hex == 3 then
			hex = hex:sub(1, 1):rep(2) .. hex:sub(2, 2):rep(2) .. hex:sub(3, 3):rep(2)
		end
		if #hex == 6 and hex:match("^%x+$") then
			return Color3.fromRGB(
				tonumber(hex:sub(1, 2), 16),
				tonumber(hex:sub(3, 4), 16),
				tonumber(hex:sub(5, 6), 16)
			)
		end
	end
	if type(value) == "table" then
		local red = value.R or value.r or value[1]
		local green = value.G or value.g or value[2]
		local blue = value.B or value.b or value[3]
		if tonumber(red) and tonumber(green) and tonumber(blue) then
			return Color3.fromRGB(
				math.clamp(tonumber(red), 0, 255),
				math.clamp(tonumber(green), 0, 255),
				math.clamp(tonumber(blue), 0, 255)
			)
		end
	end
	return fallback
end

local function buildPalette(palette, base)
	local result = table.clone(base or DEFAULT_THEMES.Dark)
	for token, value in palette or {} do
		local color = parseColor(value)
		if color then
			result[token] = color
		end
	end
	return result
end

local function memoryConfigAdapter()
	local profiles = {}
	return {
		Load = function(_, profile)
			return profiles[profile] and table.clone(profiles[profile]) or nil
		end,
		Save = function(_, profile, data)
			profiles[profile] = table.clone(data)
			return true
		end,
	}
end

function Framework.RegisterModule(first, second)
	-- Both forms are supported:
	-- Framework.RegisterModule(Module) queues it before Start.
	-- App:RegisterModule(Module) loads it immediately after Start.
	if getmetatable(first) == Framework then
		local app = first
		local moduleDefinition = second
		assert(type(moduleDefinition) == "table", "RegisterModule expects a module table")
		return app:_loadModule(moduleDefinition, moduleDefinition.Name or "RuntimeModule")
	end
	assert(type(first) == "table", "RegisterModule expects a module table")
	table.insert(registeredModules, first)
	return true
end

function Framework:_track(resource)
	table.insert(self._resources, resource)
	return resource
end

function Framework:_bindTheme(instance, property, token)
	self._themeBindings[instance] = self._themeBindings[instance] or {}
	self._themeBindings[instance][property] = token
	instance[property] = self.Theme[token]
end

function Framework:_unbindTheme(instance, property)
	local properties = self._themeBindings[instance]
	if properties then
		properties[property] = nil
	end
end

function Framework:RegisterTheme(name, palette)
	assert(type(name) == "string" and name ~= "", "Theme name is required")
	assert(type(palette) == "table", "Palette must be a table")
	self.Themes[name] = buildPalette(palette, self.Themes.Dark)
	return self.Themes[name]
end

function Framework:SetThemeColor(token, color)
	assert(type(token) == "string" and token ~= "", "Theme color token is required")
	local parsed = parseColor(color)
	assert(parsed, "Color must be Color3, a hex string, or an RGB table")
	self.Theme[token] = parsed
	for instance, properties in self._themeBindings do
		if instance.Parent then
			for property, boundToken in properties do
				if boundToken == token then
					instance[property] = parsed
				end
			end
		end
	end
	return parsed
end

function Framework:GetThemeColor(token)
	return self.Theme[token]
end

function Framework:SetTheme(name)
	local palette = self.Themes[name]
	if not palette then
		warn(("[GUIFramework] Theme %q does not exist"):format(tostring(name)))
		return false
	end
	self.ThemeName = name
	self.Theme = palette
	for instance, properties in self._themeBindings do
		if instance.Parent then
			for property, token in properties do
				if palette[token] ~= nil then
					instance[property] = palette[token]
				end
			end
		end
	end
	self.ConfigValues.__Theme = name
	return true
end

function Framework:_configKey(moduleName, options)
	return options.Flag or ("%s.%s"):format(moduleName, options.Name or "Control")
end

function Framework:_registerConfig(key, defaultValue, setter)
	if self.ConfigValues[key] == nil then
		self.ConfigValues[key] = defaultValue
	end
	if setter then
		self.ConfigSetters[key] = setter
	end
end

function Framework:SaveConfig(profile)
	local clean
	local serializable, message = pcall(function()
		clean = HttpService:JSONDecode(HttpService:JSONEncode(self.ConfigValues))
	end)
	if not serializable then
		warn("[GUIFramework] Config contains unsupported values: " .. tostring(message))
		return false
	end
	local success, result = pcall(self.ConfigAdapter.Save, self.ConfigAdapter, profile or "default", clean)
	if not success then
		warn("[GUIFramework] Config save failed: " .. tostring(result))
		return false
	end
	return result ~= false
end

function Framework:LoadConfig(profile)
	local success, data = pcall(self.ConfigAdapter.Load, self.ConfigAdapter, profile or "default")
	if not success then
		warn("[GUIFramework] Config load failed: " .. tostring(data))
		return false
	end
	if type(data) ~= "table" then
		return false
	end
	if data.__Theme then
		self:SetTheme(data.__Theme)
	end
	for key, value in data do
		self.ConfigValues[key] = value
		local setter = self.ConfigSetters[key]
		if setter then
			safeCall("apply config " .. key, setter, value, true)
		end
	end
	return true
end

function Framework:BindKey(name, keyCode, callback)
	assert(typeof(keyCode) == "EnumItem" and keyCode.EnumType == Enum.KeyCode, "Key must be Enum.KeyCode")
	assert(type(callback) == "function", "Keybind callback must be a function")
	self.Keybinds[name] = { Key = keyCode, Callback = callback }
end

function Framework:UnbindKey(name)
	self.Keybinds[name] = nil
end

function Framework:SetVisible(visible)
	self.ScreenGui.Enabled = visible == true
end

function Framework:Toggle()
	self.ScreenGui.Enabled = not self.ScreenGui.Enabled
end

