local function saveTotemDataToFile(fileName)
	local totems, err = scanTotems(true)
	if not totems then return false, err end
	if #totems == 0 then return false, "No totem blocks found inside the selected region." end

	local path    = SCHEMATIC_FOLDER .. "/" .. ensureJsonExtension(fileName)
	local existing = {}
	if isfile(path) then
		local ok, decoded = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
		if ok and type(decoded) == "table" then existing = decoded end
	end

	local totemData = {}
	for _, t in ipairs(totems) do
		table.insert(totemData, { name = t.name, upgrades = t.upgrades })
	end
	existing.TotemData = totemData
	writefile(path, HttpService:JSONEncode(existing))
	return true, #totems
end

local function loadTotemDataFromFile(fileName)
	local path = SCHEMATIC_FOLDER .. "/" .. ensureJsonExtension(fileName)
	if not isfile(path) then return nil, "File not found: " .. fileName end

	local ok, decoded = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
	if not ok or type(decoded) ~= "table" then return nil, "Could not parse schematic file." end
	if not decoded.TotemData or #decoded.TotemData == 0 then return nil, "No TotemData in this schematic." end
	return decoded.TotemData, nil
end

-- â”€â”€â”€ Totem upgrader â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

local function autoUpgradeTotems(targetTypeName, upgradeTypes, maxLevel)
	if totemUpgradeInProgress then notify("Totems", "An upgrade loop is already running.", 3); return end

	local upgradeRemote = netManaged and netManaged:FindFirstChild("UpgradeBlock")
	if not upgradeRemote then notify("Totems", "UpgradeBlock remote not found.", 5); return end

	totemUpgradeInProgress = true

	task.spawn(function()
		local totalCalls = 0
		while totemUpgradeInProgress do
			local totems, err = scanTotems()
			if not totems or #totems == 0 then
				TotemUpgradeStatus:SetDesc("No totems found â€” stopping.\n" .. tostring(err or ""))
				break
			end

			local madeAnyCall = false
			for _, t in ipairs(totems) do
				if not totemUpgradeInProgress then break end
				for _, upgradeType in ipairs(upgradeTypes) do
					if not totemUpgradeInProgress then break end
					local currentLevel = t.upgrades[upgradeType] or 0
					if maxLevel <= 0 or currentLevel < maxLevel then
						local ok, callErr = pcall(function()
							upgradeRemote:InvokeServer(t.instance, targetTypeName, upgradeType)
						end)
						if ok then
							totalCalls   = totalCalls + 1
							madeAnyCall  = true
							TotemUpgradeStatus:SetDesc(string.format(
								"Upgrading %s â†’ %s (%s)\nTotal calls: %d",
								t.name, targetTypeName, upgradeType, totalCalls
							))
						else
							TotemUpgradeStatus:SetDesc(string.format(
								"Error on %s (%s): %s", t.name, upgradeType, tostring(callErr)
							))
						end
						task.wait(totemUpgradeDelay)
					end
				end
			end

			if not madeAnyCall then
				TotemUpgradeStatus:SetDesc(string.format(
					"All totems at max level (%d). Done.\nTotal calls: %d", maxLevel, totalCalls
				))
				break
			end
			task.wait(0.1)
		end

		totemUpgradeInProgress = false
		notify("Totems", string.format("Upgrade loop finished. Total calls: %d", totalCalls), 4)
	end)
end

