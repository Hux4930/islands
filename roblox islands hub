local function getLocalIsland()
    local islands = Workspace:FindFirstChild("Islands")
    if not islands then
        return nil
    end

    for _, name in ipairs({
        "islandId",
        "islandID",
        "IslandId",
        "IslandID",
        "island",
        "Island",
    }) do
        local attributeValue = player:GetAttribute(name)
        if attributeValue ~= nil then
            local island = islands:FindFirstChild(tostring(attributeValue))
            if island then
                return island
            end
        end

        local valueObject = player:FindFirstChild(name)
        if valueObject and valueObject:IsA("ValueBase") then
            local island = islands:FindFirstChild(tostring(valueObject.Value))
            if island then
                return island
            end
        end
    end

    local userId = tostring(player.UserId)
    for _, island in ipairs(islands:GetChildren()) do
        if island.Name:find(userId, 1, true) then
            return island
        end
    end

    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local nearestIsland
    local nearestDistance = math.huge

    if rootPart then
        for _, island in ipairs(islands:GetChildren()) do
            if character:IsDescendantOf(island) then
                return island
            end

            local portal = island:FindFirstChild("portalToSpawn", true)
            local target = portal or island
            local part = target:IsA("BasePart")
                and target
                or target:FindFirstChildWhichIsA("BasePart", true)

            if part then
                local distance = (part.Position - rootPart.Position).Magnitude
                if distance < nearestDistance then
                    nearestDistance = distance
                    nearestIsland = island
                end
            end
        end
    end

    if nearestIsland then
        return nearestIsland
    end

    local children = islands:GetChildren()
    if #children == 1 then
        return children[1]
    end

    return nil
end

local function getBlockPart(block)
    if block:IsA("BasePart") then
        return block
    end
    if block:IsA("Model") then
        local root = block:FindFirstChild("Root")
        return block.PrimaryPart
            or (root and root:IsA("BasePart") and root)
            or block:FindFirstChildWhichIsA("BasePart", true)
    end
    return block:FindFirstChildWhichIsA("BasePart", true)
end

local function isVending(block)
