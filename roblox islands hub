-- Place this LocalScript in StarterPlayerScripts for a Roblox experience you own.
-- It inventories client-visible remotes and logs calls made through RemoteAudit.

local HttpService = game:GetService("HttpService")

local RemoteAudit = {}
local KEY_NAMES = {
	hash = true,
	key = true,
	nonce = true,
	secret = true,
	token = true,
}

local function getFullPath(instance)
	local parts = {}
	local current = instance

	while current and current ~= game do
		table.insert(parts, 1, current.Name)
		current = current.Parent
	end

	return "game." .. table.concat(parts, ".")
end

local function makeSerializable(value, seen)
	local valueType = typeof(value)

	if valueType == "nil"
		or valueType == "boolean"
		or valueType == "number"
		or valueType == "string" then
		return value
	end

	if valueType == "Instance" then
		return {
			type = value.ClassName,
			path = getFullPath(value),
		}
	end

	if valueType == "Vector3" or valueType == "Vector2" then
		return {
			type = valueType,
			x = value.X,
			y = value.Y,
			z = valueType == "Vector3" and value.Z or nil,
		}
	end

	if valueType == "CFrame" then
		return {
			type = "CFrame",
			components = { value:GetComponents() },
		}
	end

	if valueType == "table" then
		seen = seen or {}
		if seen[value] then
			return "<cyclic table>"
		end

		seen[value] = true
		local result = {}

		for key, childValue in pairs(value) do
			result[tostring(key)] = makeSerializable(childValue, seen)
		end

		seen[value] = nil
		return result
	end

	return {
		type = valueType,
		value = tostring(value),
	}
end

local function encodeArguments(...)
	local packed = table.pack(...)
	local output = {}

	for index = 1, packed.n do
		output[index] = makeSerializable(packed[index])
	end

	local success, encoded = pcall(HttpService.JSONEncode, HttpService, output)
	return success and encoded or tostring(output)
end

local function findKeyFields(value, path, results, seen)
	if typeof(value) ~= "table" then
		return
	end

	seen = seen or {}
	if seen[value] then
		return
	end
	seen[value] = true

	for key, childValue in pairs(value) do
		local keyText = tostring(key)
		local childPath = path .. "." .. keyText

		if KEY_NAMES[string.lower(keyText)] then
			table.insert(results, {
				path = childPath,
				value = makeSerializable(childValue),
			})
		end

		findKeyFields(childValue, childPath, results, seen)
	end
end

local function reportHitCall(remote, ...)
	local packed = table.pack(...)
	local keyFields = {}

	for index = 1, packed.n do
		findKeyFields(packed[index], ("args[%d]"):format(index), keyFields)
	end

	for name, value in pairs(remote:GetAttributes()) do
		if KEY_NAMES[string.lower(name)] then
			table.insert(keyFields, {
				path = "attributes." .. name,
				value = makeSerializable(value),
			})
		end
	end

	print("HIT REMOTE:", getFullPath(remote))
	print("HIT ARGS:", encodeArguments(table.unpack(packed, 1, packed.n)))

	if #keyFields == 0 then
		print("HIT KEYS: none explicitly present in arguments or attributes")
	else
		print("HIT KEYS:", HttpService:JSONEncode(keyFields))
	end
end

local function describeRemote(remote)
	local attributes = {}

	for name, value in pairs(remote:GetAttributes()) do
		attributes[name] = makeSerializable(value)
	end

	return {
		name = remote.Name,
		className = remote.ClassName,
		path = getFullPath(remote),
		attributes = attributes,
	}
end

function RemoteAudit.Scan()
	local remotes = {}

	for _, instance in ipairs(game:GetDescendants()) do
		if instance:IsA("RemoteEvent") or instance:IsA("RemoteFunction") then
			table.insert(remotes, describeRemote(instance))
		end
	end

	table.sort(remotes, function(left, right)
		return left.path < right.path
	end)

	print(("REMOTE AUDIT: found %d client-visible remotes"):format(#remotes))
	for index, remote in ipairs(remotes) do
		print(("[%03d] %s | %s"):format(index, remote.className, remote.path))

		if next(remote.attributes) then
			print("      Attributes:", HttpService:JSONEncode(remote.attributes))
		end
	end

	return remotes
end

function RemoteAudit.ScanHits()
	local matches = {}

	for _, instance in ipairs(game:GetDescendants()) do
		if (instance:IsA("RemoteEvent") or instance:IsA("RemoteFunction"))
			and string.find(string.lower(instance.Name), "hit", 1, true) then
			table.insert(matches, instance)
		end
	end

	table.sort(matches, function(left, right)
		return getFullPath(left) < getFullPath(right)
	end)

	print(("HIT REMOTE AUDIT: found %d name matches"):format(#matches))
	for index, remote in ipairs(matches) do
		print(("[%03d] %s | %s"):format(index, remote.ClassName, getFullPath(remote)))
	end

	return matches
end

function RemoteAudit.Fire(remote, ...)
	assert(remote:IsA("RemoteEvent"), "RemoteAudit.Fire expects a RemoteEvent")
	print("FireServer:", getFullPath(remote), "args:", encodeArguments(...))
	remote:FireServer(...)
end

function RemoteAudit.Invoke(remote, ...)
	assert(remote:IsA("RemoteFunction"), "RemoteAudit.Invoke expects a RemoteFunction")
	print("InvokeServer:", getFullPath(remote), "args:", encodeArguments(...))

	local results = table.pack(remote:InvokeServer(...))
	print("InvokeServer result:", getFullPath(remote), encodeArguments(table.unpack(results, 1, results.n)))
	return table.unpack(results, 1, results.n)
end

function RemoteAudit.FireHit(remote, ...)
	assert(remote:IsA("RemoteEvent"), "RemoteAudit.FireHit expects a RemoteEvent")
	reportHitCall(remote, ...)
	remote:FireServer(...)
end

function RemoteAudit.InvokeHit(remote, ...)
	assert(remote:IsA("RemoteFunction"), "RemoteAudit.InvokeHit expects a RemoteFunction")
	reportHitCall(remote, ...)

	local results = table.pack(remote:InvokeServer(...))
	print("HIT RESULT:", encodeArguments(table.unpack(results, 1, results.n)))
	return table.unpack(results, 1, results.n)
end

RemoteAudit.Scan()
RemoteAudit.ScanHits()

