local function getSelectionBlocks()
	if not selectionPart then return nil, "Pick a start and end block first." end
	local blocks = {}
	local island = getLocalIsland()
	local blocksContainer = island and island:FindFirstChild("Blocks")
	if not blocksContainer then return nil, "Could not find your island Blocks folder." end

	local center = selectionPart.Position
	local half = selectionPart.Size / 2
	local minPos = center - half - Vector3.new(0.01, 0.01, 0.01)
	local maxPos = center + half + Vector3.new(0.01, 0.01, 0.01)
	local seen = {}

	local function getBlockPart(block)
		if block:IsA("BasePart") then return block end
		if block:IsA("Model") then
			if block.PrimaryPart then return block.PrimaryPart end
			local root = block:FindFirstChild("Root")
			if root and root:IsA("BasePart") then return root end
		end
		return block:FindFirstChildWhichIsA("BasePart", true)
	end

	for _, block in ipairs(blocksContainer:GetChildren()) do
		local part = getBlockPart(block)
		if part then
			local pos = part.Position
			if pos.X >= minPos.X and pos.X <= maxPos.X
				and pos.Y >= minPos.Y and pos.Y <= maxPos.Y
				and pos.Z >= minPos.Z and pos.Z <= maxPos.Z
				and not seen[block]
			then
				seen[block] = true
				table.insert(blocks, {
					Name = block.Name,
					Position = pos,
					CFrame = part.CFrame,
					Instance = block,
					Part = part
				})
			end
		end
	end
	if #blocks == 0 then return nil, "No island blocks were found inside the selection." end
	return blocks
end

local function getSelectionOrigin(blocks)
	local minX, minY, minZ = math.huge, math.huge, math.huge
	for _, block in ipairs(blocks) do
		local pos = block.Position
		if pos.X < minX then minX = pos.X end
		if pos.Y < minY then minY = pos.Y end
		if pos.Z < minZ then minZ = pos.Z end
	end
	return Vector3.new(minX, minY, minZ)
end

local function buildSchematicData(blocks)
	local origin      = getSelectionOrigin(blocks)
	local originCFrame = CFrame.new(origin)
	local data = {
		FormatVersion = 2,
		BlockSize     = BLOCK_SIZE,
		Origin        = { origin.X, origin.Y, origin.Z },
		Blocks        = {}
	}

	table.sort(blocks, function(a, b)
		if a.Position.Y ~= b.Position.Y then return a.Position.Y < b.Position.Y end
		if a.Position.X ~= b.Position.X then return a.Position.X < b.Position.X end
		if a.Position.Z ~= b.Position.Z then return a.Position.Z < b.Position.Z end
		return a.Name < b.Name
	end)

	for _, block in ipairs(blocks) do
		local relative  = originCFrame:ToObjectSpace(block.CFrame)
		local blockName = block.Name
		if not data.Blocks[blockName] then data.Blocks[blockName] = {} end
		table.insert(data.Blocks[blockName], { C = { relative:GetComponents() } })
	end

	return data
end

local function stripComments(text)
	if type(text) ~= "string" then return nil end
	return text:gsub("%-%-.-\n", "\n")
end

local function decodeSchematicText(text)
	if type(text) ~= "string" or text == "" then return nil, "No schematic code was provided." end
	local cleaned = stripComments(text)
	local ok, decoded = pcall(function() return HttpService:JSONDecode(cleaned) end)
	if not ok then return nil, tostring(decoded) end
	return decoded, cleaned
end

