local function runWithPasteRenderingPaused(callback)
	local renderingPaused = false
	local pauseId = nil
	if freezeRenderingDuringPaste then
		pasteRenderPauseId = pasteRenderPauseId + 1
		pauseId = pasteRenderPauseId
		renderingPaused = pcall(function()
			RunService:Set3dRenderingEnabled(false)
		end)
		if renderingPaused then
			task.delay(15, function()
				if pasteRenderPauseId == pauseId then
					pcall(function()
						RunService:Set3dRenderingEnabled(true)
					end)
				end
			end)
		end
	end

	local ok, result = pcall(callback)

	if renderingPaused then
		pasteRenderPauseId = pasteRenderPauseId + 1
		pcall(function()
			RunService:Set3dRenderingEnabled(true)
		end)
	end

	if not ok then
		warn("[Auto Builder] Remote burst failed: " .. tostring(result))
		return 0
	end
	return result
end

local function placeBlockBatch(batch)
	local completed = 0
	local placed = 0

	for _, entry in ipairs(batch) do
		task.spawn(function()
			local success = false
			local blockCFrame = entry.cframe
			local blockName = entry.name
			if entry.block and entry.block.Parent then
				blockCFrame = entry.block.CFrame
				blockName = entry.block.Name
			end
			if blockCFrame and blockName then
				success = placeBlockRequest(blockCFrame, blockName)
			end
			entry.success = success
			if success then placed = placed + 1 end
			completed = completed + 1
		end)
	end

	while completed < #batch do task.wait() end
	return placed
end

local function placeStackedBlockBatch(stackedBatch, waitForCompletion)
	if not netManaged then return 0 end
	if not placementHashName or not placementHashValue then
		local ok = resolvePlacementHash(false)
		if not ok then return 0 end
	end
	local placeRemote = netManaged:FindFirstChild("CLIENT_BLOCK_PLACE_REQUEST")
	if not placeRemote then return 0 end

	local payloads = {}
	for _, entry in ipairs(stackedBatch) do
		entry.success = false
		local blockCFrame = entry.cframe
		local blockName = entry.name
		if entry.block and entry.block.Parent then
			blockCFrame = entry.block.CFrame
			blockName = entry.block.Name
		end
		if blockCFrame and blockName then
			table.insert(payloads, { entry = entry, args = buildPlaceArgs(blockCFrame, blockName) })
		end
	end

	local fired = 0
	local completed = 0
	for _, payload in ipairs(payloads) do
		local args = payload.args
		payload.entry.success = true
		fired = fired + 1
		task.spawn(function()
			pcall(function()
				placeRemote:InvokeServer(args)
			end)
			if waitForCompletion then
				completed = completed + 1
			end
		end)
	end

	while waitForCompletion and completed < #payloads do task.wait() end
	return fired
end

local function getGridKey(position)
	return getPositionOnlyKey(position)
