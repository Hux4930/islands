local function countPreviewBlocks()
	local count = 0
	for _, child in ipairs(cloneFolder:GetChildren()) do
		if child:IsA("BasePart") and child.Name ~= "PrimaryPart" then count = count + 1 end
	end
	return count
end

local function updatePreviewStatus()
	PreviewStatus:SetDesc(string.format("%d preview blocks  |  rotation: %dÂ°", countPreviewBlocks(), previewRotationDeg))
	if updatePreviewDragPart then updatePreviewDragPart() end
end

local function updateRotateStatus()
	RotateStatus:SetDesc(string.format("Current rotation: %dÂ°  (Y-axis, clockwise)", previewRotationDeg))
end

local function updateBlocksStatus()
	local counts = {}
	local total  = 0
	for _, child in ipairs(cloneFolder:GetChildren()) do
		if child:IsA("BasePart") and child.Name ~= "PrimaryPart" then
			local name = child.Name
			counts[name] = (counts[name] or 0) + 1
			total = total + 1
		end
	end
	if total == 0 then BlocksStatus:SetDesc("no preview loaded"); return end
	local sorted = {}
	for name in pairs(counts) do table.insert(sorted, name) end
	table.sort(sorted)
	local lines = { string.format("Total: %d blocks", total), "" }
	for _, name in ipairs(sorted) do
		table.insert(lines, string.format("%s: %d", name, counts[name]))
	end
	BlocksStatus:SetDesc(table.concat(lines, "\n"))
end

local function updateSelectionStatus()
	local startPos = selectionStartPos or (selectionStartBlock and selectionStartBlock.Position)
	local endPos   = selectionEndPos   or (selectionEndBlock   and selectionEndBlock.Position)
	if not startPos or not endPos then
		SelectionStatus:SetDesc("pick a start and end block, or use step buttons")
		return
	end
	local minX = math.min(startPos.X, endPos.X)
	local minY = math.min(startPos.Y, endPos.Y)
	local minZ = math.min(startPos.Z, endPos.Z)
	local maxX = math.max(startPos.X, endPos.X)
	local maxY = math.max(startPos.Y, endPos.Y)
	local maxZ = math.max(startPos.Z, endPos.Z)
	local sizeX = ((maxX - minX) / BLOCK_SIZE) + 1
	local sizeY = ((maxY - minY) / BLOCK_SIZE) + 1
	local sizeZ = ((maxZ - minZ) / BLOCK_SIZE) + 1
	SelectionStatus:SetDesc(string.format(
		"Start: (%d, %d, %d)\nEnd:   (%d, %d, %d)\nSize:  %dx%dx%d  (%d cells)",
		startPos.X, startPos.Y, startPos.Z,
		endPos.X, endPos.Y, endPos.Z,
		sizeX, sizeY, sizeZ, sizeX * sizeY * sizeZ
	))
end

local function rebuildSelectionPart()
	local startPos = selectionStartPos or (selectionStartBlock and selectionStartBlock.Position)
	local endPos   = selectionEndPos   or (selectionEndBlock   and selectionEndBlock.Position)
	if not startPos or not endPos then return end

	local minX = math.min(startPos.X, endPos.X)
	local minY = math.min(startPos.Y, endPos.Y)
	local minZ = math.min(startPos.Z, endPos.Z)
	local maxX = math.max(startPos.X, endPos.X)
	local maxY = math.max(startPos.Y, endPos.Y)
	local maxZ = math.max(startPos.Z, endPos.Z)

	local size   = Vector3.new((maxX - minX) + BLOCK_SIZE, (maxY - minY) + BLOCK_SIZE, (maxZ - minZ) + BLOCK_SIZE)
	local center = Vector3.new((minX + maxX) / 2, (minY + maxY) / 2, (minZ + maxZ) / 2)

	if not selectionPart then
		selectionPart             = Instance.new("Part")
		selectionPart.Name        = SELECTION_PART_NAME
		selectionPart.Anchored    = true
		selectionPart.CanCollide  = false
		selectionPart.CastShadow  = false
		selectionPart.Material    = Enum.Material.Neon
		selectionPart.Color       = Color3.fromRGB(75, 170, 255)
		selectionPart.Transparency = 0.8
		selectionPart.Parent      = Workspace
		local box = Instance.new("SelectionBox")
		box.LineThickness       = 0.05
		box.Color3              = Color3.fromRGB(75, 170, 255)
		box.SurfaceTransparency = 1
		box.Adornee             = selectionPart
		box.Parent              = selectionPart
	end

	selectionPart.Size   = size
	selectionPart.CFrame = CFrame.new(center)

	if not startMarker then startMarker = createMarker(START_MARKER_NAME, Color3.fromRGB(70, 170, 255)) end
	startMarker.CFrame = CFrame.new(startPos)

	if not endMarker then endMarker = createMarker(END_MARKER_NAME, Color3.fromRGB(255, 95, 95)) end
	endMarker.CFrame = CFrame.new(endPos)

	updateSelectionStatus()
end

local function moveCorner(corner, dx, dy, dz)
	local step = selectionMoveStep * BLOCK_SIZE
	if corner == "start" then
		local pos = selectionStartPos or (selectionStartBlock and selectionStartBlock.Position) or Vector3.new(0, 0, 0)
		selectionStartPos   = pos + Vector3.new(dx * step, dy * step, dz * step)
		selectionStartBlock = nil
		if not startMarker then startMarker = createMarker(START_MARKER_NAME, Color3.fromRGB(70, 170, 255)) end
		startMarker.CFrame = CFrame.new(selectionStartPos)
	else
		local pos = selectionEndPos or (selectionEndBlock and selectionEndBlock.Position) or Vector3.new(0, 0, 0)
		selectionEndPos   = pos + Vector3.new(dx * step, dy * step, dz * step)
		selectionEndBlock = nil
		if not endMarker then endMarker = createMarker(END_MARKER_NAME, Color3.fromRGB(255, 95, 95)) end
		endMarker.CFrame = CFrame.new(selectionEndPos)
	end
	rebuildSelectionPart()
end

local function isPreviewBlock(block)
	return block
		and block.Parent == cloneFolder
		and block:IsA("BasePart")
		and block.Name ~= "PrimaryPart"
end

local function clearPreview()
	local removed = 0
	for _, child in ipairs(cloneFolder:GetChildren()) do
		child:Destroy()
		removed = removed + 1
		if removed % 100 == 0 then task.wait() end
	end
	cloneFolder.PrimaryPart = nil
	previewRotationDeg      = 0
	updatePreviewStatus()
	updateRotateStatus()
	updateBlocksStatus()
end

local function getPreviewBlocks()
	local blocks = {}
	for _, child in ipairs(cloneFolder:GetChildren()) do
		if isPreviewBlock(child) then table.insert(blocks, child) end
	end
	return blocks
end

local function refreshPreviewStackKeys()
	for _, block in ipairs(getPreviewBlocks()) do
		block:SetAttribute("StackPositionKey", getPositionOnlyKey(block.CFrame.Position))
	end
end

local function getPartAabb(part)
	local half = part.Size / 2
	local corners = {
		Vector3.new(-half.X, -half.Y, -half.Z),
		Vector3.new(-half.X, -half.Y,  half.Z),
		Vector3.new(-half.X,  half.Y, -half.Z),
		Vector3.new(-half.X,  half.Y,  half.Z),
		Vector3.new( half.X, -half.Y, -half.Z),
		Vector3.new( half.X, -half.Y,  half.Z),
		Vector3.new( half.X,  half.Y, -half.Z),
		Vector3.new( half.X,  half.Y,  half.Z)
	}

	local minX, minY, minZ = math.huge, math.huge, math.huge
	local maxX, maxY, maxZ = -math.huge, -math.huge, -math.huge
	for _, corner in ipairs(corners) do
		local point = part.CFrame:PointToWorldSpace(corner)
		if point.X < minX then minX = point.X end
		if point.Y < minY then minY = point.Y end
		if point.Z < minZ then minZ = point.Z end
		if point.X > maxX then maxX = point.X end
		if point.Y > maxY then maxY = point.Y end
		if point.Z > maxZ then maxZ = point.Z end
	end
	return Vector3.new(minX, minY, minZ), Vector3.new(maxX, maxY, maxZ)
end

local function getPreviewBounds()
	local blocks = getPreviewBlocks()
	if #blocks == 0 then return nil end
	local minX, minY, minZ = math.huge, math.huge, math.huge
	local maxX, maxY, maxZ = -math.huge, -math.huge, -math.huge

	local function includePart(part)
		local partMin, partMax = getPartAabb(part)
		if partMin.X < minX then minX = partMin.X end
		if partMin.Y < minY then minY = partMin.Y end
		if partMin.Z < minZ then minZ = partMin.Z end
		if partMax.X > maxX then maxX = partMax.X end
		if partMax.Y > maxY then maxY = partMax.Y end
		if partMax.Z > maxZ then maxZ = partMax.Z end
	end

	for _, block in ipairs(blocks) do
		includePart(block)
		for _, child in ipairs(block:GetChildren()) do
			if child:IsA("BasePart") and child:GetAttribute("IsPreviewHitbox") == true then
				includePart(child)
			end
		end
	end
	return Vector3.new((minX + maxX) / 2, (minY + maxY) / 2, (minZ + maxZ) / 2),
		Vector3.new(maxX - minX, maxY - minY, maxZ - minZ)
end

updatePreviewDragPart = function()
	if previewDragFolder and not previewDragFolder:IsA("Folder") then
		previewDragFolder:Destroy()
		previewDragFolder = nil
		previewDragHandles = {}
	end
	if not previewDragFolder then
		previewDragFolder = Instance.new("Folder")
		previewDragFolder.Name = PREVIEW_DRAGGER_NAME
		previewDragFolder.Parent = Workspace
	end
	if next(previewDragHandles) == nil then
		for _, child in ipairs(previewDragFolder:GetChildren()) do
			child:Destroy()
		end
	end

	if not dragPreviewEnabled then
		for _, handle in pairs(previewDragHandles) do
			handle.line.Transparency = 1
			handle.knob.Transparency = 1
		end
		DragStatus:SetDesc("off")
		return
	end

	local center, size = getPreviewBounds()
	if not center then
		for _, handle in pairs(previewDragHandles) do
			handle.line.Transparency = 1
			handle.knob.Transparency = 1
		end
		DragStatus:SetDesc("load a preview, then drag an arrow handle")
		return
	end

	local maxExtent = math.max(size.X, size.Y, size.Z)
	local handleLength = math.max(BLOCK_SIZE * 4, (maxExtent / 2) + (BLOCK_SIZE * 3))
	local knobSize = BLOCK_SIZE * 0.8
	local configs = {
		Right = { axis = Vector3.new(1, 0, 0), color = Color3.fromRGB(255, 90, 90), lineSize = Vector3.new(handleLength, 0.35, 0.35), angle = CFrame.new() },
		Left = { axis = Vector3.new(-1, 0, 0), color = Color3.fromRGB(255, 90, 90), lineSize = Vector3.new(handleLength, 0.35, 0.35), angle = CFrame.new() },
		Up = { axis = Vector3.new(0, 1, 0), color = Color3.fromRGB(90, 255, 120), lineSize = Vector3.new(0.35, handleLength, 0.35), angle = CFrame.new() },
		Down = { axis = Vector3.new(0, -1, 0), color = Color3.fromRGB(90, 255, 120), lineSize = Vector3.new(0.35, handleLength, 0.35), angle = CFrame.new() },
		Forward = { axis = Vector3.new(0, 0, 1), color = Color3.fromRGB(90, 170, 255), lineSize = Vector3.new(0.35, 0.35, handleLength), angle = CFrame.new() },
		Back = { axis = Vector3.new(0, 0, -1), color = Color3.fromRGB(90, 170, 255), lineSize = Vector3.new(0.35, 0.35, handleLength), angle = CFrame.new() },
	}

	for name, config in pairs(configs) do
		local handle = previewDragHandles[name]
		if not handle then
			local line = Instance.new("Part")
			line.Name = "DragLine" .. name
			line.Anchored = true
			line.CanCollide = false
			line.CastShadow = false
			line.Material = Enum.Material.Neon
			line.Parent = previewDragFolder

			local knob = Instance.new("Part")
			knob.Name = "DragHandle" .. name
			knob.Anchored = true
			knob.CanCollide = false
			knob.CastShadow = false
			knob.Material = Enum.Material.ForceField
			knob.Shape = Enum.PartType.Ball
			knob.Parent = previewDragFolder

			handle = { line = line, knob = knob, axis = config.axis }
			previewDragHandles[name] = handle
		end

		local lineCenter = center + config.axis * (handleLength / 2)
		local knobCenter = center + config.axis * handleLength
		handle.axis = config.axis
		handle.line.Size = config.lineSize
		handle.line.CFrame = CFrame.new(lineCenter)
		handle.line.Color = config.color
		handle.line.Transparency = 0.15
		handle.knob.Size = Vector3.new(knobSize, knobSize, knobSize)
		handle.knob.CFrame = CFrame.new(knobCenter)
		handle.knob.Color = config.color
		handle.knob.Transparency = 0.2
	end
	DragStatus:SetDesc("drag a direction handle; movement snaps every 3 studs")
end

local function ensurePreviewPrimaryPart()
	if cloneFolder.PrimaryPart and cloneFolder.PrimaryPart.Parent == cloneFolder then
		return cloneFolder.PrimaryPart
	end
	for _, child in ipairs(cloneFolder:GetChildren()) do
		if isPreviewBlock(child) then cloneFolder.PrimaryPart = child; return child end
	end
	return nil
end

-- (movement is now world-axis; see movePreviewByBlocks below)

local function movePreviewByBlocks(xBlocks, yBlocks, zBlocks)
	-- Move the ENTIRE preview group by a fixed world-axis offset (like Roblox Studio's
	-- Move tool with grid snap).  Always X=right, Y=up, Z=forward â€” never camera-relative.
	local blocks = getPreviewBlocks()
	if #blocks == 0 then notify("Preview", "Load or copy a preview first.", 3); return false end

	local offset = Vector3.new(
		(tonumber(xBlocks) or 0) * BLOCK_SIZE,
		(tonumber(yBlocks) or 0) * BLOCK_SIZE,
		(tonumber(zBlocks) or 0) * BLOCK_SIZE
	)

	for _, b in ipairs(blocks) do
		b.CFrame = b.CFrame + offset
	end

	-- Keep PrimaryPart in sync so future operations still have a reference
	local primary = ensurePreviewPrimaryPart()
	if primary then cloneFolder.PrimaryPart = primary end

	refreshPreviewStackKeys()
	updatePreviewStatus()
	return true
end

-- â”€â”€â”€ Rotation & Flip â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
--[[
	Rotation is always around the Y-axis (vertical), using the bounding-box
	centre of the preview as the pivot.  Flip X and Flip Z mirror the preview
	across those axes through the same centre pivot.

	All operations work by repositioning and reorienting every block CFrame
	relative to the pivot; no model-level SetPrimaryPartCFrame tricks are needed
	so the preview stays grid-aligned after each operation.
]]

-- (centre is computed inline inside applyTransformToPreview)

--[[
	ROTATION FIX:
	All block positions are multiples of BLOCK_SIZE.  The bounding-box centre
	may land at a half-block offset when the build has an even number of blocks
	on an axis (e.g. two blocks at X=0 and X=3 â†’ centre X=1.5).

	Strategy that always keeps blocks on-grid and touching:
	  1. Express every block as an integer grid-coordinate (pos / BLOCK_SIZE).
	  2. Compute the centre in grid-coords (may be fractional .5 for even widths).
	  3. Translate so the grid-coord centre is at the origin.
	  4. Apply the integer rotation (cos/sin of 90Â° multiples are exactly 0 or Â±1).
	  5. Translate back and convert to world studs.

	Because we only support 90Â° steps the rotation matrix entries are integers,
	so no floating-point drift ever accumulates.  For flips the same logic holds.
]]

local function applyTransformToPreview(transformGridFn, rotationDelta)
	-- transformGridFn: receives (gx, gy, gz) integer grid coords relative to
	-- the grid centre, returns (nx, ny, nz) new grid coords (also integers).
	local blocks = getPreviewBlocks()
	if #blocks == 0 then notify("Rotate", "Load a preview first.", 3); return end

	-- Collect grid coordinates
	local gcoords = {}
	local minGX, minGY, minGZ =  math.huge,  math.huge,  math.huge
	local maxGX, maxGY, maxGZ = -math.huge, -math.huge, -math.huge
	for _, b in ipairs(blocks) do
		local gx = math.round(b.Position.X / BLOCK_SIZE)
		local gy = math.round(b.Position.Y / BLOCK_SIZE)
		local gz = math.round(b.Position.Z / BLOCK_SIZE)
		table.insert(gcoords, { block = b, gx = gx, gy = gy, gz = gz, rotation = b.CFrame - b.Position })
		if gx < minGX then minGX = gx end
		if gy < minGY then minGY = gy end
		if gz < minGZ then minGZ = gz end
		if gx > maxGX then maxGX = gx end
		if gy > maxGY then maxGY = gy end
		if gz > maxGZ then maxGZ = gz end
	end

	-- Centre in grid-space (may be .5 for even-width builds â€” that's fine)
	local cx = (minGX + maxGX) / 2
	local cy = (minGY + maxGY) / 2
	local cz = (minGZ + maxGZ) / 2

	-- Transform each block
	for _, entry in ipairs(gcoords) do
		-- relative grid coords (floating for even builds)
		local rx = entry.gx - cx
		local ry = entry.gy - cy
		local rz = entry.gz - cz

		local nx, ny, nz = transformGridFn(rx, ry, rz)

		-- New absolute grid coord, rounded back to integer (handles .5 centres)
		local newGX = math.round(cx + nx)
		local newGY = math.round(cy + ny)
		local newGZ = math.round(cz + nz)

		local newPosition = Vector3.new(newGX * BLOCK_SIZE, newGY * BLOCK_SIZE, newGZ * BLOCK_SIZE)
		local newRotation = entry.rotation
		if rotationDelta then
			newRotation = rotationDelta * newRotation
		end
		entry.block.CFrame = CFrame.new(newPosition) * newRotation
	end

	refreshPreviewStackKeys()
	updatePreviewStatus()
	updateBlocksStatus()
	updatePreviewDragPart()
end

local function rotatePreviewY(angleDeg)
	-- For 90Â° multiples: cos/sin are exactly 0 or Â±1 â€” no float error.
	local rad       = math.rad(angleDeg)
	local cosA      = math.round(math.cos(rad))   -- -1, 0, or 1
	local sinA      = math.round(math.sin(rad))   -- -1, 0, or 1

	applyTransformToPreview(function(rx, ry, rz)
		-- Standard Y-axis rotation (clockwise = positive angle)
		return cosA * rx + sinA * rz,
		       ry,
		       -sinA * rx + cosA * rz
	end, CFrame.Angles(0, rad, 0))

	previewRotationDeg = (previewRotationDeg + angleDeg) % 360
	updateRotateStatus()
	notify("Rotate", string.format("Rotated to %dÂ°", previewRotationDeg), 2)
end

local function flipPreviewX()
	applyTransformToPreview(function(rx, ry, rz) return -rx, ry, rz end)
	notify("Rotate", "Flipped on X axis.", 2)
end

local function flipPreviewZ()
	applyTransformToPreview(function(rx, ry, rz) return rx, ry, -rz end)
	notify("Rotate", "Flipped on Z axis.", 2)
end

local function flipPreviewY()
	applyTransformToPreview(function(rx, ry, rz) return rx, -ry, rz end)
	notify("Rotate", "Flipped vertically (Y axis).", 2)
end

