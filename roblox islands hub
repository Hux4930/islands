	Callback = function()
		local previewBlocks = getPreviewBlocks()
		if #previewBlocks == 0 then notify("Preview", "Load or copy a preview first.", 4); return end
		local snapshot = {}
		for _, b in ipairs(previewBlocks) do table.insert(snapshot, { name = b.Name, cframe = b.CFrame }) end
		local added = 0
		for copyIndex = 1, duplicateCount do
			local offset = Vector3.new(
				duplicateOffsetX * copyIndex * BLOCK_SIZE,
				duplicateOffsetY * copyIndex * BLOCK_SIZE,
				duplicateOffsetZ * copyIndex * BLOCK_SIZE
			)
			for _, b in ipairs(snapshot) do
				if spawnPreviewBlock(b.name, b.cframe + offset) then added = added + 1 end
			end
		end
		updatePreviewStatus()
		updateBlocksStatus()
		notify("Preview", string.format("Added %d duplicate preview blocks.", added), 4)
	end
})

