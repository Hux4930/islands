			table.insert(tools, child)
		end
	end
	table.sort(tools, function(left, right)
		return left.Name:lower() < right.Name:lower()
	end)

	for _, tool in ipairs(tools) do
		local button = Instance.new("TextButton")
		button.Size = UDim2.new(1, -8, 0, 34)
		button.BackgroundColor3 = Color3.fromRGB(38, 42, 52)
		button.BorderSizePixel = 0
		button.Font = Enum.Font.Gotham
		button.Text = ("%s | client-visible amount: %d"):format(tool.Name, getQuantity(tool))
		button.TextColor3 = Color3.fromRGB(225, 228, 235)
		button.TextSize = 13
		button.Parent = list
		table.insert(itemButtons, button)

		button.Activated:Connect(function()
			selectedTool = tool
			amountBox.Text = tostring(getQuantity(tool))
			status.Text = ("Selected %s. Server must independently verify ownership and amount."):format(tool.Name)
		end)
	end

	if #tools == 0 then
		status.Text = "Backpack contains no Tools."
	end
