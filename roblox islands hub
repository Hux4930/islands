local blockIndex = {}

local function registerBlock(block)
    local settings = BLOCK_SETTINGS[block.Name]
    if not settings then
        return
    end

    local health = block:FindFirstChild("Health")
    local part = block:FindFirstChildWhichIsA("BasePart")
    if health and part then
        blockIndex[block] = {
            block = block,
            part = part,
            health = health,
            fullHealth = settings.health,
            targetHealth = settings.targetHealth,
        }
    end
end

local function registerFromDescendant(descendant)
    local current = descendant

    while current and current ~= workspace do
        if BLOCK_SETTINGS[current.Name] then
            registerBlock(current)
            return
        end
        current = current.Parent
    end
end

local function unregisterFromDescendant(descendant)
    local current = descendant

    while current and current ~= workspace do
        if blockIndex[current] then
            blockIndex[current] = nil
            return
        end
        current = current.Parent
    end
end

