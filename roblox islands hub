local function runEmbedded(name, context)
    local source = EMBEDDED_SCRIPTS[name]
    if not source then
        context:Notify({
            Title = "Missing tool",
            Content = name .. " was not embedded.",
            Type = "Error",
        })
        return
    end

    task.spawn(function()
        local compiled, compileError = loadstring(source, "=" .. name)
        if not compiled then
            warn("[Unified Hub] " .. name .. " compile failed:", compileError)
            context:Notify({
                Title = name,
                Content = "Compile failed. Check the console.",
                Type = "Error",
            })
            return
        end

        local ok, runtimeError = xpcall(compiled, debug.traceback)
        if not ok then
            warn("[Unified Hub] " .. name .. " failed:", runtimeError)
            context:Notify({
                Title = name,
                Content = "Stopped with an error. Check the console.",
                Type = "Error",
            })
        end
    end)
end

local function stopHook(name)
    local hook = environment[name]
    if type(hook) == "function" then
        pcall(hook)
        return true
    end
    return false
end

