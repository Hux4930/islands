local function depositInventoryOnce()
	local tool = findDepositTool()
	if not tool then
		return false, selectedDepositItem == ""
			and "choose an item first"
			or ("waiting for " .. selectedDepositItem)
	end
	local chest = refreshDepositChest()
	if not chest then return false, "waiting for a nearby diamondChestT2" end
	local remote = netManaged and netManaged:FindFirstChild("CLIENT_CHEST_TRANSACTION")
	if not remote or not remote:IsA("RemoteFunction") then
		return false, "CLIENT_CHEST_TRANSACTION was not found"
	end
	local owned = getDepositQuantity(tool)
	if owned <= 0 then return false, "the selected stack is empty" end
	local amount = math.min(depositSettings.amount, owned)
	local ok, result = pcall(function()
		return remote:InvokeServer({
			chest = chest,
			amount = amount,
			tool = tool,
			action = "deposit"
		})
	end)
	if not ok then return false, "deposit error: " .. tostring(result) end
	task.wait(0.05)
	local replacement = findDepositTool()
	return true, replacement
		and string.format(
			"deposited %d %s | visible amount: %d",
			amount,
			selectedDepositItem,
			getDepositQuantity(replacement)
		)
		or string.format("deposited %d %s | stack finished", amount, selectedDepositItem)
end

local function stopInventoryDeposit(message)
	depositRunning = false
	if message then DepositStatus:SetDesc(message) end
