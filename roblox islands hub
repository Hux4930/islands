local function getNearestBlock(playerPos)
    local nearest
    local nearestDistanceSquared = math.huge
    local aliveCount = 0
    local mineableCount = 0

    for block, blockData in pairs(blockIndex) do
        local health = blockData.health
        local part = blockData.part

        if not block.Parent or not health.Parent or not part.Parent then
            blockIndex[block] = nil
            continue
        end

        local healthValue = health.Value
        if healthValue > blockData.targetHealth then
            aliveCount += 1

            mineableCount += 1
            local offset = part.Position - playerPos
            local distanceSquared = offset:Dot(offset)

            if distanceSquared < nearestDistanceSquared then
                nearestDistanceSquared = distanceSquared
                nearest = blockData
            end
        end
    end

    return nearest, mineableCount, aliveCount
end

local function tweenToBlock(rootPart, targetPos, tweeningHorse)
    local abovePos = targetPos + Vector3.new(0, 3, 0)
    local distance = (abovePos - rootPart.Position).Magnitude

    if distance <= 1 then
        return true
    end

    local wasAnchored = rootPart.Anchored
    if tweeningHorse then
        rootPart.Anchored = true
    end

    local tweenSpeed = getTweenSpeed(tweeningHorse)
    local tweenTime = distance / tweenSpeed
    local tween = TweenService:Create(
        rootPart,
        TweenInfo.new(tweenTime, Enum.EasingStyle.Linear),
        { CFrame = CFrame.new(abovePos) }
    )

    print(
        "[Miner] Tweening",
        math.floor(distance),
        "studs at speed",
        tweenSpeed,
        "to",
        targetPos
    )
    tween:Play()
    tween.Completed:Wait()

    if tweeningHorse and rootPart.Parent then
        rootPart.Anchored = wasAnchored
    end

    return true
end

