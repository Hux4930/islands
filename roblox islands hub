local depositDefaults = {
	itemName = "",
	amount = 1,
	delay = 0.5,
	persistent = false,
	autoStart = false
}

local function copyDepositDefaults()
	local result = {}
	for key, value in pairs(depositDefaults) do result[key] = value end
	return result
end

local function loadDepositSettings()
	local settings = copyDepositDefaults()
	if not isfile(DEPOSIT_SETTINGS_FILE) then return settings end
	local ok, decoded = pcall(function()
		return HttpService:JSONDecode(readfile(DEPOSIT_SETTINGS_FILE))
	end)
	if not ok or type(decoded) ~= "table" then return settings end
	if type(decoded.itemName) == "string" then settings.itemName = decoded.itemName end
	settings.amount = math.clamp(math.floor(tonumber(decoded.amount) or 1), 1, 1000000)
	settings.delay = math.clamp(tonumber(decoded.delay) or 0.5, 0.1, 60)
	settings.persistent = decoded.persistent == true
	settings.autoStart = decoded.autoStart == true
	return settings
end

local depositSettings = loadDepositSettings()
local depositRunning = false
local selectedDepositItem = depositSettings.itemName
