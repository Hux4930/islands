local function invokeDeposit(amount)
	refreshChest()

	if not selectedTool or selectedTool.Parent ~= backpack then
		status.Text = "Select a Tool that is still in the Backpack."
		return
	end
	if not selectedChest then
		status.Text = "No test chest was found."
		return
	end
	if typeof(amount) ~= "number" or amount ~= amount or amount == math.huge or amount == -math.huge then
		status.Text = "Amount must be a finite number."
		return
	end

	amount = math.floor(amount)
	status.Text = ("Invoking audit request: %s x %d..."):format(selectedTool.Name, amount)

	local ok, result = pcall(function()
		return remote:InvokeServer({
			chest = selectedChest,
			player_tracking_category = "studio_security_audit",
			amount = amount,
			tool = selectedTool,
			action = "deposit",
		})
	end)

	if ok then
		status.Text = ("Server returned: %s. Check server inventory and audit logs."):format(tostring(result))
	else
		status.Text = ("Server rejected/error: %s"):format(tostring(result))
	end
end

