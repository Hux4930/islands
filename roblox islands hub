function OnlineBuilds.GetNames()
	local names = {}
	for name in pairs(OnlineBuilds.Entries) do table.insert(names, name) end
	table.sort(names, function(a, b) return a:lower() < b:lower() end)
	return names
end

function OnlineBuilds.NormalizeEntry(name, value)
	if type(value) == "table" and (value.Blocks or value.blocks) then
		return { name = tostring(name), data = value }
	end
	if type(value) == "string" then
		return { name = tostring(name), url = value }
	end
	if type(value) ~= "table" then return nil end

	local entryName = tostring(value.name or value.Name or value.title or value.Title or name)
	local entryData = value.data or value.Data or value.schematic or value.Schematic
	local entryUrl = value.url or value.URL or value.raw or value.Raw
	if type(entryData) == "table" and (entryData.Blocks or entryData.blocks) then
		return { name = entryName, data = entryData }
	end
	if type(entryUrl) == "string" and entryUrl ~= "" then
		return { name = entryName, url = entryUrl }
	end
	return nil
end

function OnlineBuilds.ParseManifest(text)
	local decoded, decodeError = decodeSchematicText(text)
	if not decoded then
		local entries = {}
		for line in tostring(text):gmatch("[^\r\n]+") do
			local name, url = line:match("^%s*([^|]+)%s*|%s*(https?://%S+)%s*$")
			if name and url then entries[name] = { name = name, url = url } end
		end
		if next(entries) then return entries end
		return nil, "The builds file is not valid JSON: " .. tostring(decodeError)
	end

	if decoded.Blocks or decoded.blocks then
		local name = decoded.Name or decoded.name
			or (decoded.Metadata and (decoded.Metadata.Name or decoded.Metadata.name))
			or "Remote Build"
		return { [tostring(name)] = { name = tostring(name), data = decoded } }
	end

	local source = decoded.builds or decoded.Builds or decoded
	local entries = {}
	if #source > 0 then
		for index, value in ipairs(source) do
			local fallbackName = "Build " .. tostring(index)
			local entry = OnlineBuilds.NormalizeEntry(fallbackName, value)
			if entry then entries[entry.name] = entry end
		end
	else
		for name, value in pairs(source) do
			local entry = OnlineBuilds.NormalizeEntry(name, value)
			if entry then entries[entry.name] = entry end
		end
	end

	if not next(entries) then
		return nil, "The builds manifest contains no usable build entries."
	end
	return entries
end

function OnlineBuilds.Refresh()
	OnlineBuilds.Status:SetDesc("downloading build list...")
	local ok, response = pcall(function() return game:HttpGet(OnlineBuilds.URL, true) end)
	if not ok then
		OnlineBuilds.Status:SetDesc("download failed")
		return false, tostring(response)
	end

	local entries, parseError = OnlineBuilds.ParseManifest(response)
	if not entries then
		OnlineBuilds.Entries = {}
		if OnlineBuilds.Dropdown then OnlineBuilds.Dropdown:SetValues({}) end
		OnlineBuilds.Status:SetDesc(tostring(parseError))
		return false, parseError
	end

	OnlineBuilds.Entries = entries
	local names = OnlineBuilds.GetNames()
	OnlineBuilds.Selected = names[1]
	if OnlineBuilds.Dropdown then
		OnlineBuilds.Dropdown:SetValues(names)
		pcall(function() OnlineBuilds.Dropdown:SetValue(OnlineBuilds.Selected) end)
	end
	OnlineBuilds.Status:SetDesc(string.format("%d build(s) available", #names))
	return true, #names
end

function OnlineBuilds.ResolveData(entry)
	if not entry then return nil, "Select an online build first." end
	if entry.data then return entry.data end
	if type(entry.url) ~= "string" or entry.url == "" then
		return nil, "This build has no data or URL."
	end

	local url = entry.url
	if not url:match("^https?://") then
		url = "https://raw.githubusercontent.com/Hux4930/NOT-SCRIPTS-I-REPEAT-NOT-SCRIPTS/refs/heads/main/"
			.. url:gsub("^/+", "")
	end
	url = url:gsub(" ", "%%20")
	local ok, response = pcall(function() return game:HttpGet(url, true) end)
	if not ok then return nil, tostring(response) end
	local decoded, decodeError = decodeSchematicText(response)
	if not decoded then return nil, decodeError end
	entry.data = decoded
	return decoded
end

function OnlineBuilds.PrepareClone(instance)
	local clone = instance:Clone()
	for _, descendant in ipairs(clone:GetDescendants()) do
		if descendant:IsA("Script") or descendant:IsA("LocalScript") then
			descendant:Destroy()
		elseif descendant:IsA("BasePart") then
			descendant.Anchored = true
			descendant.CanCollide = false
			descendant.CanTouch = false
			descendant.CanQuery = false
		end
	end
	if clone:IsA("BasePart") then
		clone.Anchored = true
		clone.CanCollide = false
		clone.CanTouch = false
		clone.CanQuery = false
	end
	return clone
end

function OnlineBuilds.FindTemplate(blockName)
	local buildDisplayFolder = ReplicatedStorage:FindFirstChild("Blocks")
	if not buildDisplayFolder then return nil end
	local normalized = normalizePreviewBlockName(blockName)
	return buildDisplayFolder:FindFirstChild(normalized)
		or buildDisplayFolder:FindFirstChild(blockName)
end

function OnlineBuilds.AddTemplate(displayModel, blockName, worldCFrame)
	local template = OnlineBuilds.FindTemplate(blockName)
	if not template then return false end

	if template:IsA("Model") then
		local clone = OnlineBuilds.PrepareClone(template)
		clone.Parent = displayModel
		clone:PivotTo(worldCFrame)
		return true
	end
	if template:IsA("BasePart") then
		local clone = OnlineBuilds.PrepareClone(template)
		clone.CFrame = worldCFrame
		clone.Parent = displayModel
		return true
	end

	local root = template:FindFirstChild("Root", true)
	if root and root:IsA("BasePart") then
		local clone = OnlineBuilds.PrepareClone(root)
		clone.Name = blockName
		clone.CFrame = worldCFrame
		clone.Parent = displayModel
		return true
	end
	return false
end

