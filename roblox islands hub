local function startInventoryDeposit(singleDeposit)
	if depositRunning then DepositStatus:SetDesc("auto deposit is already running"); return end
	if selectedDepositItem == "" then DepositStatus:SetDesc("choose an item first"); return end
	depositRunning = true
	DepositStatus:SetDesc(singleDeposit and "depositing once..." or "auto deposit started")
	task.spawn(function()
		repeat
			local success, message = depositInventoryOnce()
			DepositStatus:SetDesc(message)
			if singleDeposit then break end
			if not success and not depositSettings.persistent then break end
			task.wait(success and depositSettings.delay or 1)
		until not depositRunning
		depositRunning = false
	end)
end

