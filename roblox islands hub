			dragging = false
		end
	end))
	table.insert(connections, UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			window.Position = startPosition + UDim2.fromOffset(delta.X, delta.Y)
		end
	end))

	local handle = {
		Instance = window,
		Overlay = overlay,
		Container = content,
		Visible = false,
	}
	function handle:Open()
		self.Visible = true
		overlay.Visible = true
		window.Size = UDim2.fromOffset(300, 220)
		tween(window, 0.2, { Size = options.Size or UDim2.fromOffset(500, 420) })
	end
	function handle:Close()
		self.Visible = false
		overlay.Visible = false
	end
	function handle:Toggle()
		if self.Visible then self:Close() else self:Open() end
	end
	function handle:Destroy()
		for _, connection in connections do
			connection:Disconnect()
		end
		overlay:Destroy()
		local index = table.find(app.CustomWindows, self)
		if index then
			table.remove(app.CustomWindows, index)
		end
	end

	table.insert(self.CustomWindows, handle)
	table.insert(connections, close.Activated:Connect(function() handle:Close() end))
	if options.CloseOnBackdrop ~= false then
		table.insert(connections, overlay.Activated:Connect(function(input)
			if input then
				handle:Close()
			end
		end))
	end
	return handle
end

function Framework:_createNotificationContainer()
	local container = create("Frame", {
		Name = "Notifications",
		AnchorPoint = Vector2.new(1, 1),
		Position = UDim2.new(1, -18, 1, -18),
		Size = UDim2.fromOffset(330, 420),
		BackgroundTransparency = 1,
		Parent = self.ScreenGui,
	})
	create("UIListLayout", {
		HorizontalAlignment = Enum.HorizontalAlignment.Right,
		VerticalAlignment = Enum.VerticalAlignment.Bottom,
