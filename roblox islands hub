            end
        end

        local valueObject = player:FindFirstChild(name)
        if valueObject and valueObject:IsA("ValueBase") then
            local island = islands:FindFirstChild(tostring(valueObject.Value))
            if island then
                print("[Miner] Found player island from value:", island.Name)
                return island
            end
        end
    end

    local userId = tostring(player.UserId)
    for _, island in ipairs(islands:GetChildren()) do
        if string.find(island.Name, userId, 1, true) then
            print("[Miner] Found player island from UserId:", island.Name)
            return island
        end
