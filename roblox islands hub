local function setHighlight(block, stackSize)
	clearHighlight(block)

	local color = STACK_COLORS[stackSize]
	if not color then return end

	local highlight = Instance.new("Highlight")
	highlight.Name = HIGHLIGHT_NAME
	highlight.Adornee = block
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.FillColor = color
	highlight.FillTransparency = 0.45
	highlight.OutlineColor = color
	highlight.OutlineTransparency = 0
	highlight.Parent = block
end

local function refreshHighlights()
	local previewBlocks = getPreviewBlocks()
	local entries = {}
	local parent = {}
	local indexesByCell = {}

	local function find(index)
		while parent[index] ~= index do
			parent[index] = parent[parent[index]]
			index = parent[index]
		end
		return index
	end

	local function union(firstIndex, secondIndex)
		local firstRoot = find(firstIndex)
		local secondRoot = find(secondIndex)
		if firstRoot ~= secondRoot then
			parent[secondRoot] = firstRoot
		end
	end

	for index, block in ipairs(previewBlocks) do
		clearHighlight(block)
		parent[index] = index
		entries[index] = {
			block = block,
			hitboxes = getBlockHitboxes(block)
		}

		local candidates = {}
		local cells = getCandidateCells(entries[index].hitboxes)
		for cell in pairs(cells) do
			for _, otherIndex in ipairs(indexesByCell[cell] or {}) do
				candidates[otherIndex] = true
			end
		end

		for otherIndex in pairs(candidates) do
			if blocksOverlap(entries[index], entries[otherIndex]) then
				union(index, otherIndex)
			end
		end

		for cell in pairs(cells) do
			indexesByCell[cell] = indexesByCell[cell] or {}
			table.insert(indexesByCell[cell], index)
		end
	end

	local groups = {}
	for index, entry in ipairs(entries) do
		local root = find(index)
		groups[root] = groups[root] or {}
		table.insert(groups[root], entry.block)
	end

	for _, group in pairs(groups) do
		for _, block in ipairs(group) do
			setHighlight(block, #group)
		end
	end
end

local function clearAllHighlights()
	for _, block in ipairs(getPreviewBlocks()) do
		clearHighlight(block)
	end
