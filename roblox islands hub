	local chest = updateChestStatus()
	if not chest then
		return false, "Waiting for a nearby diamondChestT2."
	end

	local owned = getQuantity(tool)
	if owned <= 0 then
		return false, "The selected stack is empty."
	end

	local requestAmount = math.min(config.amount, owned)
	local ok, result = pcall(function()
		return remote:InvokeServer({
			chest = chest,
			amount = requestAmount,
			tool = tool,
			action = "deposit",
		})
	end)

	if not ok then
		return false, "Deposit error: " .. tostring(result)
	end

	task.wait(0.05)
	local replacement = findSelectedTool()
	if replacement then
		return true, ("Deposited %d %s | visible amount: %d"):format(
			requestAmount,
			selectedToolName,
			getQuantity(replacement)
		)
	end
	return true, ("Deposited %d %s | stack finished."):format(requestAmount, selectedToolName)
end

local function stopDeposit(message)
	running = false
	if message then
		setStatus(message)
	end
end

local function startDeposit(singleDeposit)
	if running then
		setStatus("Auto deposit is already running.")
		return
	end
	if selectedToolName == "" then
		setStatus("Choose an item first.")
		return
	end

	running = true
	setStatus(singleDeposit and "Depositing once..." or "Auto deposit started.")

	task.spawn(function()
		repeat
			local success, message = depositOnce()
			setStatus(message)

			if singleDeposit then
				break
			end

			if not success and not config.persistent then
				break
			end

			task.wait(success and config.delay or 1)
		until not running or destroyed

		running = false
	end)
end

