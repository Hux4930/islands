local function tweenToCompletionPortal(rootPart, tweeningHorse)
    local frame = findCompletionPortalFrame(rootPart)

    if not frame then
        warn("[Miner] Completion portal was not found; joining immediately")
        return false
    end

    local targetPart
    if frame:IsA("BasePart") then
        targetPart = frame
    elseif frame:IsA("Model") then
        targetPart = frame.PrimaryPart or frame:FindFirstChildWhichIsA("BasePart", true)
    end

    if not targetPart then
        warn("[Miner] Completion portal Frame has no usable BasePart")
        return false
    end

    print("[Miner] Mining complete. Tweening to completion portal")
    local tweenOk, tweenError = pcall(
        tweenToBlock,
        rootPart,
        targetPart.Position,
        tweeningHorse
    )

    if not tweenOk then
        warn("[Miner] Completion portal tween failed:", tweenError)
        return false
    end

    task.wait(2)
    return true
end

local function hitBlock(blockData)
    local blockHits = 0
    local blockWasMined = false

    while running
        and blockHits < MAX_HITS_PER_BLOCK
        and blockData.health
        and blockData.health.Value > blockData.targetHealth do
        local hitPosition = blockData.part.Position
        local healthBeforeHit = blockData.health.Value
        debugHit("[Miner] Sending hit:", blockData.block:GetFullName(), "health:", healthBeforeHit)

        local invokeOk, invokeResult = pcall(function()
            return remote:InvokeServer({
                [capturedHashKey] = capturedHash,
                part = blockData.part,
                block = blockData.block,
                norm = Vector3.new(0, 1, 0),
                pos = hitPosition,
            })
        end)

        if not invokeOk then
            warn("Block hit failed:", invokeResult)
            break
        end

        blockHits += 1
        totalHits += 1
        hitsThisSecond += 1
        task.wait(0.2)

        if not blockData.health.Parent then
            debugHit("Hit accepted: block removed")
            minedBelowThreshold = true
            blockWasMined = true
            break
        end

        local healthAfterHit = blockData.health.Value
        healthLabel.Text = string.format(
            "Health: %d / %d (target %d)",
            math.floor(healthAfterHit),
            blockData.fullHealth,
            blockData.targetHealth
        )
        debugHit(
            "Hit audit:",
            blockData.block:GetFullName(),
            "serverResult:",
            invokeResult,
            "health:",
            healthBeforeHit,
            "->",
            healthAfterHit
        )

        if healthBeforeHit > blockData.targetHealth
            and healthAfterHit <= blockData.targetHealth then
            minedBelowThreshold = true
            blockWasMined = true
            break
        end

        if healthAfterHit <= 0 then
            blockWasMined = true
            break
        end
    end

    if blockWasMined then
        recordMinedBlock()
    end
end

