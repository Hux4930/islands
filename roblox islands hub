		Parent = container,
	})
	self.NotificationContainer = container
end

function Framework:Notify(options)
	options = if type(options) == "string" then { Content = options } else options or {}
	local kind = options.Type or "Info"
	local card = create("Frame", {
		Name = "Notification",
		Size = UDim2.fromOffset(0, 78),
		ClipsDescendants = true,
		Parent = self.NotificationContainer,
	})
	self:_bindTheme(card, "BackgroundColor3", "Surface")
	corner(card, 10)
	local token = if kind == "Error" then "Error" elseif kind == "Success" then "Success" else "Accent"
	local accent = create("Frame", {
		Size = UDim2.new(0, 4, 1, 0),
		BorderSizePixel = 0,
		Parent = card,
	})
	self:_bindTheme(accent, "BackgroundColor3", token)
	local title = self:_makeLabel(card, options.Title or "Notification", UDim2.new(1, -28, 0, 22), UDim2.fromOffset(16, 8))
	title.Font = Enum.Font.GothamSemibold
	local content = self:_makeLabel(card, options.Content or options.Message or "", UDim2.new(1, -28, 0, 36), UDim2.fromOffset(16, 31))
	content.TextWrapped = true
	content.TextYAlignment = Enum.TextYAlignment.Top
	content.TextSize = 12
	self:_bindTheme(content, "TextColor3", "MutedText")
	tween(card, 0.25, { Size = UDim2.fromOffset(330, 78) })
	task.delay(math.max(0.5, tonumber(options.Duration) or 4), function()
		if card.Parent then
			tween(card, 0.2, { Size = UDim2.fromOffset(0, 78), BackgroundTransparency = 1 })
			task.delay(0.22, function()
				card:Destroy()
			end)
		end
	end)
	return card
end

function Framework:_newContext(moduleDefinition)
	local app = self
	local moduleName = moduleDefinition.Name
	local tabName = moduleDefinition.Tab or moduleName
	local tab = if moduleDefinition.Type == "UI" then self:AddTab(tabName) else nil
	local context = {
		Name = moduleName,
		Type = moduleDefinition.Type,
		Framework = self,
		Services = self.Services,
		Tab = tab,
		Container = tab and tab.Page or nil,
	}

	function context:AddTab(name)
		local newTab = app:AddTab(name)
		self.Tab = newTab
		self.Container = newTab.Page
		return newTab
	end
	function context:AddLazyTab(options)
		assert(type(options) == "table" and type(options.Name) == "string", "AddLazyTab requires Name")
		assert(type(options.Loader) == "function", "AddLazyTab requires Loader")
		return app:AddTab({
			Name = options.Name,
			Loader = function(tabHandle)
				local tabContext = setmetatable({
					Tab = tabHandle,
					Container = tabHandle.Page,
				}, { __index = context })
				options.Loader(tabContext)
			end,
		})
	end
	function context:AddLoadstringTab(options)
		assert(type(options) == "table" and type(options.Name) == "string", "AddLoadstringTab requires Name")
		return self:AddLazyTab({
			Name = options.Name,
			Loader = function(tabContext)
				local source = options.Source
				if type(source) == "function" then
					source = source()
				end
				assert(type(source) == "string" and source ~= "", "Loadstring tab Source must return code")
				assert(type(loadstring) == "function", "loadstring is unavailable in this Roblox environment")
				local chunk, compileError = loadstring(source)
				assert(chunk, compileError)
				if type(setfenv) == "function" and type(getfenv) == "function" then
					setfenv(chunk, setmetatable({
						Context = tabContext,
					}, { __index = getfenv() }))
				end
				local result = chunk()
				if type(result) == "function" then
					result(tabContext)
				elseif type(result) == "table" and type(result.Load) == "function" then
					result.Load(tabContext)
				end
			end,
		})
	end
	function context:CreateWindow(options)
		options = options or {}
		local window = app:CreateCustomWindow(options)
		local windowContext = setmetatable({
			Tab = nil,
			Container = window.Container,
			Window = window,
		}, { __index = context })
		window.Context = windowContext
		if type(options.Build) == "function" then
			self:_callback((options.Title or "Custom GUI") .. ".Build", options.Build, windowContext, window)
		end
		return window
	end
	function context:OpenWindow(options)
		local window = self:CreateWindow(options)
		window:Open()
		return window
	end
	function context:SelectTab(name) return app:SelectTab(name) end
	function context:Notify(options) return app:Notify(options) end
	function context:BindKey(name, key, callback) return app:BindKey(moduleName .. "." .. name, key, callback) end
	function context:SaveConfig(profile) return app:SaveConfig(profile) end
	function context:LoadConfig(profile) return app:LoadConfig(profile) end
	function context:SetTheme(name) return app:SetTheme(name) end
	function context:RegisterTheme(name, palette) return app:RegisterTheme(name, palette) end
	function context:SetThemeColor(token, color) return app:SetThemeColor(token, color) end
	function context:GetThemeColor(token) return app:GetThemeColor(token) end
	function context:_container()
		if not self.Container then
			error(("Logic module %q must call Context:AddTab() before adding UI"):format(moduleName), 2)
		end
		return self.Container
	end
	function context:_callback(name, callback, ...)
		return safeCall(("%s.%s"):format(moduleName, name), callback, ...)
	end

	function context:AddLabel(options)
		options = if type(options) == "string" then { Name = options } else options
		assert(type(options) == "table" and type(options.Name) == "string", "AddLabel requires Name")
		local card = app:_makeCard(self:_container(), options.Name, options.Height or 44)
		local label = app:_makeLabel(card, options.Name)
		label.TextWrapped = true
		local customColor = parseColor(options.Color)
		if customColor then
			app:_unbindTheme(label, "TextColor3")
			label.TextColor3 = customColor
		end
		local handle = { Instance = card }
		function handle:Set(value)
			label.Text = tostring(value)
			card:SetAttribute("SearchText", label.Text)
		end
		function handle:Get() return label.Text end
		function handle:Destroy() card:Destroy() end
		return handle
	end

	function context:AddSection(options)
		options = if type(options) == "string" then { Name = options } else options
		assert(type(options) == "table" and type(options.Name) == "string", "AddSection requires Name")
		local section = create("TextLabel", {
			Name = options.Name,
			Size = UDim2.new(1, 0, 0, 30),
			BackgroundTransparency = 1,
			Font = Enum.Font.GothamBold,
			Text = string.upper(options.Name),
			TextSize = 11,
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = self:_container(),
		})
		section:SetAttribute("Searchable", false)
		app:_bindTheme(section, "TextColor3", "MutedText")
		local customColor = parseColor(options.Color)
		if customColor then
			app:_unbindTheme(section, "TextColor3")
			section.TextColor3 = customColor
		end
		return { Instance = section, Destroy = function() section:Destroy() end }
	end

	function context:AddSeparator(options)
		options = options or {}
		local holder = create("Frame", {
			Name = options.Name or "Separator",
			Size = UDim2.new(1, 0, 0, options.Height or 12),
			BackgroundTransparency = 1,
			Parent = self:_container(),
		})
		holder:SetAttribute("Searchable", false)
		local line = create("Frame", {
			AnchorPoint = Vector2.new(0, 0.5),
			Position = UDim2.fromScale(0, 0.5),
			Size = UDim2.new(1, 0, 0, options.Thickness or 1),
			BorderSizePixel = 0,
			Parent = holder,
		})
		local customColor = parseColor(options.Color)
		if customColor then
			line.BackgroundColor3 = customColor
		else
			app:_bindTheme(line, "BackgroundColor3", "Border")
		end
		return { Instance = holder, Destroy = function() holder:Destroy() end }
	end

	function context:AddButton(options)
		assert(type(options) == "table" and type(options.Name) == "string", "AddButton requires Name")
		local card = app:_makeCard(self:_container(), options.Name, 44)
		local button = create("TextButton", {
			Size = UDim2.fromScale(1, 1),
			BackgroundTransparency = 1,
			AutoButtonColor = false,
			Font = Enum.Font.GothamSemibold,
			Text = options.Name,
			TextSize = 13,
			Parent = card,
		})
		local textColor = parseColor(options.TextColor)
		if textColor then
			app:_unbindTheme(button, "TextColor3")
			button.TextColor3 = textColor
		else
			app:_bindTheme(button, "TextColor3", "Text")
		end
		local backgroundColor = parseColor(options.Color)
		if backgroundColor then
			app:_unbindTheme(card, "BackgroundColor3")
			card.BackgroundColor3 = backgroundColor
		end
		local customWindow = nil
		app:_track(button.Activated:Connect(function()
			if options.OpenWindow then
				if not customWindow or not customWindow.Instance.Parent or options.OpenWindow.Rebuild == true then
					if customWindow then customWindow:Destroy() end
					customWindow = self:CreateWindow(options.OpenWindow)
				end
				customWindow:Open()
			end
			self:_callback(options.Name, options.Callback)
		end))
		local handle = { Instance = card }
		function handle:GetWindow() return customWindow end
		function handle:Destroy()
			if customWindow then customWindow:Destroy() end
			card:Destroy()
		end
		return handle
	end

	function context:AddWindowButton(options)
		assert(type(options) == "table" and type(options.Name) == "string", "AddWindowButton requires Name")
		assert(type(options.Window) == "table", "AddWindowButton requires Window options")
		return self:AddButton({
			Name = options.Name,
			Color = options.Color,
			TextColor = options.TextColor,
			Callback = options.Callback,
			OpenWindow = options.Window,
		})
	end

	function context:AddColorPicker(options)
		assert(type(options) == "table" and type(options.Name) == "string", "AddColorPicker requires Name")
		local key = app:_configKey(moduleName, options)
		local value = parseColor(options.Default, app.Theme.Accent)
		local card = app:_makeCard(self:_container(), options.Name, 68)
		app:_makeLabel(card, options.Name, UDim2.new(1, -150, 1, 0))

		local preview = create("TextButton", {
			AnchorPoint = Vector2.new(1, 0.5),
			Position = UDim2.new(1, -112, 0.5, 0),
			Size = UDim2.fromOffset(34, 34),
			AutoButtonColor = false,
			Text = "",
			Parent = card,
		})
		corner(preview, 8)
		local previewStroke = create("UIStroke", { Thickness = 1, Transparency = 0.25, Parent = preview })
		app:_bindTheme(previewStroke, "Color", "Border")

		local box = create("TextBox", {
			AnchorPoint = Vector2.new(1, 0.5),
			Position = UDim2.new(1, -14, 0.5, 0),
			Size = UDim2.fromOffset(88, 34),
			ClearTextOnFocus = false,
			Font = Enum.Font.Code,
			Text = colorToHex(value),
			TextSize = 12,
			Parent = card,
		})
		app:_bindTheme(box, "BackgroundColor3", "SurfaceAlt")
		app:_bindTheme(box, "TextColor3", "Text")
		corner(box, 8)

		local handle = { Instance = card }
		function handle:Set(newValue, silent)
			local parsed = parseColor(newValue)
			if not parsed then
				box.Text = colorToHex(value)
				return false
			end
			value = parsed
			preview.BackgroundColor3 = value
			box.Text = colorToHex(value)
			app.ConfigValues[key] = box.Text
			if options.ThemeToken then
				app:SetThemeColor(options.ThemeToken, value)
			end
			if not silent then
				context:_callback(options.Name, options.Callback, value, box.Text)
			end
			return true
		end
		function handle:Get() return value end
		function handle:GetHex() return colorToHex(value) end
		function handle:Destroy() card:Destroy() end

		app:_track(box.FocusLost:Connect(function()
			handle:Set(box.Text)
		end))
		app:_track(preview.Activated:Connect(function()
			box:CaptureFocus()
		end))
		app:_registerConfig(key, colorToHex(value), function(saved, silent)
			handle:Set(saved, silent)
		end)
		handle:Set(value, true)
		return handle
	end

	function context:AddToggle(options)
		assert(type(options) == "table" and type(options.Name) == "string", "AddToggle requires Name")
		local card = app:_makeCard(self:_container(), options.Name, 48)
		app:_makeLabel(card, options.Name, UDim2.new(1, -76, 1, 0))
		local track = create("TextButton", {
			AnchorPoint = Vector2.new(1, 0.5),
			Position = UDim2.new(1, -14, 0.5, 0),
			Size = UDim2.fromOffset(44, 24),
			AutoButtonColor = false,
			Text = "",
			Parent = card,
		})
		corner(track, 12)
		local knob = create("Frame", {
			AnchorPoint = Vector2.new(0, 0.5),
			Position = UDim2.new(0, 3, 0.5, 0),
			Size = UDim2.fromOffset(18, 18),
			Parent = track,
		})
		corner(knob, 9)
		app:_bindTheme(knob, "BackgroundColor3", "Text")
		local value = options.Default == true
		local key = app:_configKey(moduleName, options)
		local handle = { Instance = card }
		function handle:Set(newValue, silent)
			value = newValue == true
			app:_bindTheme(track, "BackgroundColor3", if value then "Accent" else "SurfaceAlt")
			tween(knob, 0.16, {
				Position = if value then UDim2.new(1, -21, 0.5, 0) else UDim2.new(0, 3, 0.5, 0),
			})
			app.ConfigValues[key] = value
			if not silent then context:_callback(options.Name, options.Callback, value) end
		end
		function handle:Get() return value end
		function handle:Destroy() card:Destroy() end
		app:_registerConfig(key, value, function(saved, silent) handle:Set(saved, silent) end)
		app:_track(track.Activated:Connect(function() handle:Set(not value) end))
		handle:Set(value, true)
		return handle
	end

	function context:AddSlider(options)
		assert(type(options) == "table" and type(options.Name) == "string", "AddSlider requires Name")
		local minimum = tonumber(options.Min) or 0
		local maximum = tonumber(options.Max) or 100
		assert(maximum > minimum, "Slider Max must be greater than Min")
		local step = tonumber(options.Step) or 1
		local value = clampNumber(options.Default, minimum, maximum, step)
		local key = app:_configKey(moduleName, options)
		local card = app:_makeCard(self:_container(), options.Name, 64)
		app:_makeLabel(card, options.Name, UDim2.new(1, -90, 0, 36))
		local valueLabel = app:_makeLabel(card, "", UDim2.fromOffset(64, 36), UDim2.new(1, -78, 0, 0))
		valueLabel.TextXAlignment = Enum.TextXAlignment.Right
		local track = create("TextButton", {
			Position = UDim2.fromOffset(14, 43),
			Size = UDim2.new(1, -28, 0, 6),
			AutoButtonColor = false,
			Text = "",
			Parent = card,
		})
		app:_bindTheme(track, "BackgroundColor3", "SurfaceAlt")
		corner(track, 3)
		local fill = create("Frame", { Size = UDim2.fromScale(0, 1), BorderSizePixel = 0, Parent = track })
		app:_bindTheme(fill, "BackgroundColor3", "Accent")
		corner(fill, 3)
		local draggingSlider = false
		local handle = { Instance = card }
		function handle:Set(newValue, silent)
			value = clampNumber(newValue, minimum, maximum, step)
			fill.Size = UDim2.fromScale((value - minimum) / (maximum - minimum), 1)
			valueLabel.Text = tostring(value)
			app.ConfigValues[key] = value
			if not silent then context:_callback(options.Name, options.Callback, value) end
		end
		function handle:Get() return value end
		function handle:Destroy() card:Destroy() end
		local function update(position)
			local ratio = math.clamp((position.X - track.AbsolutePosition.X) / math.max(track.AbsoluteSize.X, 1), 0, 1)
			handle:Set(minimum + (maximum - minimum) * ratio)
		end
		app:_track(track.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				draggingSlider = true
				update(input.Position)
			end
		end))
		app:_track(UserInputService.InputChanged:Connect(function(input)
			if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				update(input.Position)
			end
		end))
		app:_track(UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				draggingSlider = false
			end
		end))
		app:_registerConfig(key, value, function(saved, silent) handle:Set(saved, silent) end)
		handle:Set(value, true)
		return handle
	end

	function context:AddTextbox(options)
		assert(type(options) == "table" and type(options.Name) == "string", "AddTextbox requires Name")
		local key = app:_configKey(moduleName, options)
		local value = tostring(options.Default or "")
		local card = app:_makeCard(self:_container(), options.Name, 66)
		app:_makeLabel(card, options.Name, UDim2.new(1, -28, 0, 30), UDim2.fromOffset(14, 2))
		local box = create("TextBox", {
			Position = UDim2.fromOffset(12, 31),
			Size = UDim2.new(1, -24, 0, 27),
			ClearTextOnFocus = false,
			Font = Enum.Font.Gotham,
			PlaceholderText = options.Placeholder or "Enter text...",
			Text = value,
			TextSize = 12,
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = card,
		})
		app:_bindTheme(box, "BackgroundColor3", "SurfaceAlt")
		app:_bindTheme(box, "TextColor3", "Text")
		app:_bindTheme(box, "PlaceholderColor3", "MutedText")
		corner(box, 6)
		padding(box, 9, 0)
		local handle = { Instance = card }
		function handle:Set(newValue, silent)
			value = tostring(newValue or "")
			box.Text = value
			app.ConfigValues[key] = value
			if not silent then context:_callback(options.Name, options.Callback, value) end
		end
		function handle:Get() return value end
		function handle:Destroy() card:Destroy() end
		app:_track(box.FocusLost:Connect(function(enterPressed)
			handle:Set(box.Text)
			if enterPressed then self:_callback(options.Name .. " submitted", options.OnSubmit, value) end
		end))
		app:_registerConfig(key, value, function(saved, silent) handle:Set(saved, silent) end)
		return handle
	end

	function context:AddDropdown(options)
		assert(type(options) == "table" and type(options.Name) == "string", "AddDropdown requires Name")
		assert(type(options.Options) == "table", "AddDropdown requires Options")
		local values = options.Options
		local value = options.Default or values[1]
		local key = app:_configKey(moduleName, options)
		local open = false
		local card = app:_makeCard(self:_container(), options.Name, 66)
		card.ClipsDescendants = true
		app:_makeLabel(card, options.Name, UDim2.new(1, -28, 0, 30), UDim2.fromOffset(14, 2))
		local selector = create("TextButton", {
			Position = UDim2.fromOffset(12, 31),
			Size = UDim2.new(1, -24, 0, 27),
			AutoButtonColor = false,
			Font = Enum.Font.Gotham,
			Text = tostring(value),
			TextSize = 12,
			Parent = card,
		})
		app:_bindTheme(selector, "BackgroundColor3", "SurfaceAlt")
		app:_bindTheme(selector, "TextColor3", "Text")
		corner(selector, 6)
		local list = create("Frame", {
			Position = UDim2.fromOffset(12, 64),
			Size = UDim2.new(1, -24, 0, #values * 30),
			BackgroundTransparency = 1,
			Parent = card,
		})
		create("UIListLayout", { Padding = UDim.new(0, 3), Parent = list })
		local handle = { Instance = card }
		function handle:Set(newValue, silent)
			if not table.find(values, newValue) then return end
			value = newValue
			selector.Text = tostring(value)
			app.ConfigValues[key] = value
			if not silent then context:_callback(options.Name, options.Callback, value) end
		end
		function handle:Get() return value end
		function handle:Destroy() card:Destroy() end
		for _, option in values do
			local item = create("TextButton", {
				Size = UDim2.new(1, 0, 0, 27),
				AutoButtonColor = false,
				Font = Enum.Font.Gotham,
				Text = tostring(option),
				TextSize = 12,
				Parent = list,
			})
			app:_bindTheme(item, "BackgroundColor3", "SurfaceAlt")
			app:_bindTheme(item, "TextColor3", "Text")
			corner(item, 6)
			app:_track(item.Activated:Connect(function()
				handle:Set(option)
				open = false
				card.Size = UDim2.new(1, 0, 0, 66)
			end))
		end
		app:_track(selector.Activated:Connect(function()
			open = not open
			card.Size = UDim2.new(1, 0, 0, if open then 69 + #values * 30 else 66)
		end))
		app:_registerConfig(key, value, function(saved, silent) handle:Set(saved, silent) end)
		handle:Set(value, true)
		return handle
	end

	return context
end

function Framework:_validateModule(moduleDefinition, sourceName)
	if type(moduleDefinition) ~= "table" then
		return false, sourceName .. " must return a table"
	end
	if type(moduleDefinition.Name) ~= "string" or moduleDefinition.Name == "" then
		return false, sourceName .. " is missing Name"
	end
	if moduleDefinition.Type ~= "UI" and moduleDefinition.Type ~= "Logic" then
		return false, sourceName .. " Type must be UI or Logic"
	end
	if type(moduleDefinition.Load) ~= "function" then
		return false, sourceName .. " is missing Load(Context)"
	end
	return true
end

function Framework:_loadModule(moduleDefinition, sourceName)
	local valid, reason = self:_validateModule(moduleDefinition, sourceName)
	if not valid then
		warn("[GUIFramework] Skipped module: " .. reason)
		self.FailedModules[sourceName] = reason
		return false
	end
	if self.LoadedModules[moduleDefinition.Name] then
		warn(("[GUIFramework] Duplicate module name %q skipped"):format(moduleDefinition.Name))
		return false
	end
	local context = self:_newContext(moduleDefinition)
	local success, message = xpcall(function()
		moduleDefinition.Load(context)
	end, debug.traceback)
	if not success then
		warn(("[GUIFramework] Module %q failed:\n%s"):format(moduleDefinition.Name, tostring(message)))
		self.FailedModules[moduleDefinition.Name] = message
		self:Notify({
			Title = "Module failed",
			Content = moduleDefinition.Name .. " could not be loaded.",
			Type = "Error",
		})
		return false
	end
	self.LoadedModules[moduleDefinition.Name] = {
		Definition = moduleDefinition,
		Context = context,
	}
	return true
end

function Framework:_loadRegisteredModules()
	local candidates = {}
	for _, definition in registeredModules do
		table.insert(candidates, {
			Name = definition.Name or "RegisteredModule",
			Definition = definition,
		})
	end
	table.sort(candidates, function(a, b)
		local aOrder = tonumber(a.Definition.Order) or 100
		local bOrder = tonumber(b.Definition.Order) or 100
		if aOrder == bOrder then
			return tostring(a.Definition.Name) < tostring(b.Definition.Name)
		end
		return aOrder < bOrder
	end)
	for _, candidate in candidates do
		self:_loadModule(candidate.Definition, candidate.Name)
	end
end

function Framework:Destroy()
	for index = #self.CustomWindows, 1, -1 do
		self.CustomWindows[index]:Destroy()
	end
	for _, loaded in self.LoadedModules do
		if type(loaded.Definition.Unload) == "function" then
			safeCall(loaded.Definition.Name .. ".Unload", loaded.Definition.Unload, loaded.Context)
		end
	end
	for index = #self._resources, 1, -1 do
		local resource = self._resources[index]
		if typeof(resource) == "RBXScriptConnection" then
			resource:Disconnect()
		elseif typeof(resource) == "Instance" then
			resource:Destroy()
		elseif type(resource) == "function" then
			safeCall("cleanup", resource)
		end
	end
	if self.ScreenGui then
		self.ScreenGui:Destroy()
	end
	table.clear(self._resources)
end

function Framework.Start(options)
	local localPlayer = Players.LocalPlayer
	if not localPlayer then
		error(
			"GUIFramework is client UI. Put this code in a LocalScript under "
				.. "StarterPlayer > StarterPlayerScripts, not a server Script.",
			2
		)
	end
	options = options or {}
	local themes = {}
	for name, palette in DEFAULT_THEMES do
		themes[name] = table.clone(palette)
	end
	for name, palette in options.Themes or {} do
		themes[name] = buildPalette(palette, themes.Dark)
	end
	if options.Colors then
		themes.Custom = buildPalette(options.Colors, themes.Dark)
	end
	local requestedTheme = options.Theme or "Dark"
	local themeName = if themes[requestedTheme] then requestedTheme elseif options.Colors then "Custom" else "Dark"
	local self = setmetatable({
		Themes = themes,
		ThemeName = themeName,
		Theme = themes[themeName],
		Tabs = {},
		ActiveTab = nil,
		Minimized = false,
		Keybinds = {},
		ConfigValues = {},
		ConfigSetters = {},
		ConfigAdapter = options.ConfigAdapter or memoryConfigAdapter(),
		LoadedModules = {},
		FailedModules = {},
		CustomWindows = {},
		Services = options.Services or {},
		_resources = {},
		_themeBindings = setmetatable({}, { __mode = "k" }),
	}, Framework)

	self:_createWindow(options)
	self:_createNotificationContainer()
	self.ConfigValues.__Theme = themeName

	self:_track(UserInputService.InputBegan:Connect(function(input, processed)
		if processed or UserInputService:GetFocusedTextBox() then
			return
		end
		for name, binding in self.Keybinds do
			if input.KeyCode == binding.Key then
				safeCall("keybind " .. name, binding.Callback)
			end
		end
	end))
	self:BindKey("__FrameworkToggle", options.ToggleKey or Enum.KeyCode.RightShift, function()
		self:Toggle()
	end)

	self:_loadRegisteredModules()

	if options.AutoLoadConfig then
		self:LoadConfig(options.ConfigProfile)
	end
	if options.ReadyNotification ~= false then
		self:Notify({
			Title = options.Title or "GUI Framework",
			Content = ("Loaded %d module(s)."):format(
				(function()
					local count = 0
					for _ in self.LoadedModules do count += 1 end
					return count
				end)()
			),
			Type = "Success",
		})
	end
	return self
end

