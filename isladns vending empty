repeat
    task.wait()
until game:IsLoaded() and game:GetService("Players").LocalPlayer

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local Workspace = game:GetService("Workspace")
local HttpService = game:GetService("HttpService")

local player = Players.LocalPlayer
local environment = getgenv()

local TWEEN_SPEED = 30
local HEIGHT_ABOVE_BLOCK = 12
local HIT_RANGE = 30
local MAX_HITS_PER_VENDING = 30
local HIT_DELAY = 0.12
local PLACE_RETRIES = 5
local PLACE_RETRY_DELAY = 0.75
local RESTORE_VERIFY_RADIUS = 1.5
local PLACE_CACHE_FILE = "IslandsSchematicOnly/Islands/Cache/block_place_cache.json"
local REMOTE_DEBUG_FOLDER = "_ISLANDS_SCHEMATIC_ONLY"

if environment.AutoVendingRelocatorRunning then
    warn("[Vending Relocator] Already running")
    return
end

environment.AutoVendingRelocatorRunning = true
environment.StopAutoVendingRelocator = false

local function log(...)
    print("[Vending Relocator]", ...)
end

local function stopWithError(message)
    environment.AutoVendingRelocatorRunning = false
    error("[Vending Relocator] " .. tostring(message), 0)
end

local function getNetManaged()
    local current = ReplicatedStorage
    for _, name in ipairs({
        "rbxts_include",
        "node_modules",
        "@rbxts",
        "net",
        "out",
        "_NetManaged",
    }) do
        current = current:WaitForChild(name, 10)
        if not current then
            return nil
        end
    end
    return current
end

local function getLocalIsland()
    local islands = Workspace:FindFirstChild("Islands")
    if not islands then
        return nil
    end

    local userId = tostring(player.UserId)
    for _, island in ipairs(islands:GetChildren()) do
        if island.Name:find(userId, 1, true) then
            return island
        end
    end

    local children = islands:GetChildren()
    if #children == 1 then
        return children[1]
    end

    return nil
end

local function getBlockPart(block)
    if block:IsA("BasePart") then
        return block
    end
    if block:IsA("Model") then
        local root = block:FindFirstChild("Root")
        return block.PrimaryPart
            or (root and root:IsA("BasePart") and root)
            or block:FindFirstChildWhichIsA("BasePart", true)
    end
    return block:FindFirstChildWhichIsA("BasePart", true)
end

local function isVending(block)
    return block.Name:lower():find("vending", 1, true) ~= nil
end

local function equipHotbarOne()
    local character = player.Character or player.CharacterAdded:Wait()
    local humanoid = character:WaitForChild("Humanoid", 10)

    for _ = 1, 3 do
        pcall(function()
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.One, false, game)
            task.wait(0.08)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.One, false, game)
        end)
        task.wait(0.3)
        if character:FindFirstChildWhichIsA("Tool") then
            return true
        end
    end

    local backpack = player:FindFirstChild("Backpack")
    local tool = backpack and backpack:FindFirstChildWhichIsA("Tool")
    if humanoid and tool then
        humanoid:EquipTool(tool)
        return true
    end

    return false
end

local function discoverHitHash()
    assert(
        type(getgc) == "function"
            and type(getinfo) == "function"
            and type(getprotos) == "function"
            and type(getconstants) == "function",
        "Executor is missing functions needed to discover the mining hash"
    )

    for _, candidate in pairs(getgc(true)) do
        if type(candidate) == "function" and getinfo(candidate).name == "onBlockHit" then
            for _, prototype in pairs(getprotos(candidate)) do
                local constants = getconstants(prototype)
                if table.find(constants, "Get") then
                    local key = constants[8]
                    local directHash = constants[9]
                    local rightA = constants[10]
                    local rightB = constants[11]

                    if type(key) == "string" and type(directHash) == "string" then
                        return key, directHash
                    end
                    if type(key) == "string"
                        and type(rightA) == "string"
                        and type(rightB) == "string"
                    then
                        return key, rightA .. rightB
                    end
                end
            end
        end
    end

    return nil, nil
end

local function getBlockControllerScript()
    local playerScripts = player:FindFirstChild("PlayerScripts")
    if not playerScripts then
        return nil
    end

    for _, descendant in ipairs(playerScripts:GetDescendants()) do
        local lowerName = descendant.Name:lower()
        if lowerName == "block-controller"
            or lowerName == "blockcontroller"
            or lowerName == "block-controller-client"
        then
            return descendant
        end
    end

    return nil
end

local function validHashPair(key, value)
    return type(key) == "string"
        and key ~= ""
        and type(value) == "string"
        and value ~= ""
        and key ~= "blockType"
        and key ~= "cframe"
        and key ~= "upperBlock"
        and key ~= "CLIENT_BLOCK_PLACE_REQUEST"
        and key ~= "Get"
end

local function readBuilderPlacementHash()
    local debugFolder = game:FindFirstChild(REMOTE_DEBUG_FOLDER)
    local keyValue = debugFolder and debugFolder:FindFirstChild("BlockPlaceHashData")
    local hashValue = debugFolder and debugFolder:FindFirstChild("BlockPlaceHash")
    local key = keyValue and keyValue.Value
    local hash = hashValue and hashValue.Value

    if validHashPair(key, hash) then
        return key, hash, "auto-builder debug values"
    end

    if type(isfile) == "function"
        and type(readfile) == "function"
        and isfile(PLACE_CACHE_FILE)
    then
        local readOk, decoded = pcall(function()
            return HttpService:JSONDecode(readfile(PLACE_CACHE_FILE))
        end)
        if readOk
            and type(decoded) == "table"
            and tonumber(decoded.placeVersion) == game.PlaceVersion
            and validHashPair(decoded.hashName, decoded.hashValue)
        then
            return decoded.hashName, decoded.hashValue, "auto-builder cache"
        end
    end

    return nil, nil, nil
end

local function extractPlacementHash(constants, trustedFunction)
    if type(constants) ~= "table" then
        return nil, nil
    end

    local markerCount = 0
    for _, constant in ipairs(constants) do
        if constant == "CLIENT_BLOCK_PLACE_REQUEST"
            or constant == "blockType"
            or constant == "cframe"
            or constant == "upperBlock"
        then
            markerCount += 1
        end
    end

    if not trustedFunction and markerCount < 2 then
        return nil, nil
    end

    local knownLayouts = {
        { 23, 24 },
        { 23, 25, 26 },
        { 8, 9 },
        { 8, 10, 11 },
    }

    for _, layout in ipairs(knownLayouts) do
        local key = constants[layout[1]]
        local value
        if #layout == 2 then
            value = constants[layout[2]]
        else
            local left = constants[layout[2]]
            local right = constants[layout[3]]
            if type(left) == "string" and type(right) == "string" then
                value = left .. right
            end
        end

        if validHashPair(key, value) then
            return key, value
        end
    end

    local markers = {
        CLIENT_BLOCK_PLACE_REQUEST = true,
        blockType = true,
        cframe = true,
        upperBlock = true,
        Get = true,
    }

    for markerIndex, constant in ipairs(constants) do
        if markers[constant] then
            local firstIndex = math.max(1, markerIndex - 18)
            local lastIndex = math.min(#constants, markerIndex + 18)

            for keyIndex = firstIndex, lastIndex do
                local key = constants[keyIndex]
                if type(key) == "string" and not markers[key] then
                    for valueIndex = keyIndex + 1, math.min(lastIndex, keyIndex + 4) do
                        local value = constants[valueIndex]
                        if validHashPair(key, value) then
                            return key, value
                        end

                        local secondHalf = constants[valueIndex + 1]
                        if type(value) == "string"
                            and type(secondHalf) == "string"
                            and validHashPair(key, value .. secondHalf)
                        then
                            return key, value .. secondHalf
                        end
                    end
                end
            end
        end
    end

    return nil, nil
end

local function discoverPlacementHash()
    local cachedKey, cachedHash, cachedSource = readBuilderPlacementHash()
    if cachedKey then
        return cachedKey, cachedHash, cachedSource
    end

    assert(
        type(getgc) == "function" and type(getconstants) == "function",
        "Executor is missing getgc/getconstants needed to discover the placement hash"
    )

    local blockController = getBlockControllerScript()
    local scanned = {}

    local function scanFunction(candidate, source, trustedFunction)
        if type(candidate) ~= "function" or scanned[candidate] then
            return nil, nil, nil
        end
        scanned[candidate] = true

        local constantsOk, constants = pcall(getconstants, candidate)
        if constantsOk then
            local key, hash = extractPlacementHash(constants, trustedFunction)
            if key then
                return key, hash, source
            end
        end

        if type(getprotos) == "function" then
            local protosOk, prototypes = pcall(getprotos, candidate)
            if protosOk and type(prototypes) == "table" then
                for _, prototype in pairs(prototypes) do
                    local key, hash, prototypeSource = scanFunction(
                        prototype,
                        source .. " prototype",
                        trustedFunction
                    )
                    if key then
                        return key, hash, prototypeSource
                    end
                end
            end
        end

        return nil, nil, nil
    end

    if blockController and type(getfenv) == "function" then
        for _, candidate in pairs(getgc(true)) do
            if type(candidate) == "function" then
                local environmentOk, functionEnvironment = pcall(getfenv, candidate)
                if environmentOk
                    and functionEnvironment
                    and functionEnvironment.script == blockController
                then
                    local key, hash, source = scanFunction(
                        candidate,
                        "block controller",
                        true
                    )
                    if key then
                        return key, hash, source
                    end
                end
            end
        end
    end

    for _, candidate in pairs(getgc(true)) do
        if type(candidate) == "function" then
            local functionName = ""
            if type(getinfo) == "function" then
                local infoOk, info = pcall(getinfo, candidate)
                if infoOk and info then
                    functionName = tostring(info.name or ""):lower()
                end
            end

            local source = functionName:find("place", 1, true)
                and ("placement function " .. functionName)
                or "global placement scan"
            local key, hash, foundSource = scanFunction(
                candidate,
                source,
                functionName:find("place", 1, true) ~= nil
            )
            if key then
                return key, hash, foundSource
            end
        elseif type(candidate) == "table"
            and candidate.cframe
            and candidate.blockType
        then
            for key, value in pairs(candidate) do
                if validHashPair(key, value) then
                    return key, value, "live placement payload"
                end
            end
        end
    end

    return nil, nil, nil
end

local function tweenRootTo(rootPart, targetCFrame)
    local distance = (targetCFrame.Position - rootPart.Position).Magnitude
    if distance <= 0.5 then
        rootPart.CFrame = targetCFrame
        return true
    end

    local tween = TweenService:Create(
        rootPart,
        TweenInfo.new(distance / TWEEN_SPEED, Enum.EasingStyle.Linear),
        { CFrame = targetCFrame }
    )
    tween:Play()
    tween.Completed:Wait()
    return not environment.StopAutoVendingRelocator
end

local function tweenAbove(rootPart, targetCFrame)
    local targetPosition = targetCFrame.Position + Vector3.new(0, HEIGHT_ABOVE_BLOCK, 0)
    return tweenRootTo(rootPart, CFrame.new(targetPosition))
end

local function findMatchingBlock(blocksFolder, name, position)
    for _, block in ipairs(blocksFolder:GetChildren()) do
        if block.Name == name then
            local part = getBlockPart(block)
            if part and (part.Position - position).Magnitude <= RESTORE_VERIFY_RADIUS then
                return block
            end
        end
    end
    return nil
end

local function snapshotVendings(blocksFolder)
    local vendings = {}

    for _, block in ipairs(blocksFolder:GetChildren()) do
        if isVending(block) then
            local part = getBlockPart(block)
            local health = block:FindFirstChild("Health")
            if part and health then
                table.insert(vendings, {
                    block = block,
                    part = part,
                    health = health,
                    name = block.Name,
                    cframe = part.CFrame,
                })
            else
                warn("[Vending Relocator] Skipping vending without a part or Health:", block:GetFullName())
            end
        end
    end

    return vendings
end

local function sortNearestFirst(vendings, startPosition)
    local ordered = {}
    local remaining = table.clone(vendings)
    local currentPosition = startPosition

    while #remaining > 0 do
        local nearestIndex = 1
        local nearestDistance = math.huge

        for index, vending in ipairs(remaining) do
            local distance = (vending.cframe.Position - currentPosition).Magnitude
            if distance < nearestDistance then
                nearestDistance = distance
                nearestIndex = index
            end
        end

        local nearest = table.remove(remaining, nearestIndex)
        table.insert(ordered, nearest)
        currentPosition = nearest.cframe.Position
    end

    return ordered
end

local netManaged = getNetManaged()
if not netManaged then
    stopWithError("_NetManaged was not found")
end

local hitRemote = netManaged:FindFirstChild("CLIENT_BLOCK_HIT_REQUEST")
local placeRemote = netManaged:FindFirstChild("CLIENT_BLOCK_PLACE_REQUEST")
if not hitRemote or not placeRemote then
    stopWithError("Mining or placement remote was not found")
end

local hitHashKey, hitHash = discoverHitHash()
if not hitHashKey or not hitHash then
    stopWithError("Could not discover the mining hash")
end

local placeHashKey, placeHash, placeHashSource = discoverPlacementHash()
if not placeHashKey or not placeHash then
    stopWithError("Could not discover the placement hash")
end
log("Placement hash discovered from:", placeHashSource)

local island = getLocalIsland()
local blocksFolder = island and island:FindFirstChild("Blocks")
if not blocksFolder then
    stopWithError("Could not find your island Blocks folder")
end

local character = player.Character or player.CharacterAdded:Wait()
local rootPart = character:WaitForChild("HumanoidRootPart", 10)
if not rootPart then
    stopWithError("HumanoidRootPart was not found")
end

local startingCFrame = rootPart.CFrame
local vendings = sortNearestFirst(snapshotVendings(blocksFolder), rootPart.Position)
if #vendings == 0 then
    environment.AutoVendingRelocatorRunning = false
    warn("[Vending Relocator] No vending machines found on your island")
    return
end

log(("Saved %d vending machine position(s)"):format(#vendings))
equipHotbarOne()

local mined = {}
for index, vending in ipairs(vendings) do
    if environment.StopAutoVendingRelocator then
        break
    end
    if not vending.block.Parent or not vending.part.Parent then
        warn("[Vending Relocator] Vending disappeared before mining:", vending.name)
        continue
    end

    log(("Mining %d/%d: %s"):format(index, #vendings, vending.name))
    tweenAbove(rootPart, vending.cframe)

    local hits = 0
    while not environment.StopAutoVendingRelocator
        and vending.block.Parent
        and vending.health.Parent
        and vending.health.Value > 0
        and hits < MAX_HITS_PER_VENDING
    do
        if (vending.part.Position - rootPart.Position).Magnitude > HIT_RANGE then
            tweenAbove(rootPart, vending.cframe)
        end

        local invokeOk, invokeError = pcall(function()
            hitRemote:InvokeServer({
                [hitHashKey] = hitHash,
                part = vending.part,
                block = vending.block,
                norm = Vector3.new(0, 24, 0),
                pos = vending.part.Position,
            })
        end)

        if not invokeOk then
            warn("[Vending Relocator] Hit failed:", invokeError)
            break
        end

        hits += 1
        task.wait(HIT_DELAY)
    end

    task.wait(0.35)
    if not vending.block.Parent or not vending.health.Parent or vending.health.Value <= 0 then
        table.insert(mined, vending)
    else
        warn("[Vending Relocator] Could not mine:", vending.name)
    end
end

log(("Mined %d/%d. Restoring saved positions"):format(#mined, #vendings))

local restored = 0
for index, vending in ipairs(mined) do
    log(("Restoring %d/%d: %s"):format(index, #mined, vending.name))
    tweenAbove(rootPart, vending.cframe)

    local placed = false
    for attempt = 1, PLACE_RETRIES do
        if findMatchingBlock(blocksFolder, vending.name, vending.cframe.Position) then
            placed = true
            break
        end

        local placeOk, placeError = pcall(function()
            placeRemote:InvokeServer({
                [placeHashKey] = placeHash,
                upperBlock = false,
                cframe = vending.cframe,
                blockType = vending.name,
            })
        end)

        if not placeOk then
            warn(
                ("[Vending Relocator] Place attempt %d failed for %s: %s")
                    :format(attempt, vending.name, tostring(placeError))
            )
        end

        task.wait(PLACE_RETRY_DELAY)
    end

    if not placed then
        placed = findMatchingBlock(blocksFolder, vending.name, vending.cframe.Position) ~= nil
    end

    if placed then
        restored += 1
    else
        warn("[Vending Relocator] Failed to restore:", vending.name, vending.cframe.Position)
    end
end

log("Returning to starting position")
pcall(function()
    tweenRootTo(rootPart, startingCFrame)
end)

environment.AutoVendingRelocatorRunning = false
log(("Finished. Restored %d/%d mined vending machine(s)"):format(restored, #mined))
